<Router AppAssembly="@typeof(App).Assembly" NotFoundPage="typeof(Pages.NotFound)">
    <Found Context="routeData">
        @if (IsPublicRoute(routeData.PageType))
        {
            <RouteView RouteData="@routeData" Layout="@typeof(Layout.PublicLayout)" />
        }
        else
        {
            <RouteView RouteData="@routeData" DefaultLayout="@typeof(Layout.MainLayout)" />
        }
        <FocusOnNavigate RouteData="@routeData" Selector="h1" />
    </Found>
</Router>

@code {
    private static bool IsPublicRoute(Type pageType)
    {
        // Public pages that should use PublicLayout (no menu/toolbar/status bar)
        var pageName = pageType.Name;
        return pageName == "Login" || pageName == "ForgotPassword" || pageName == "Register";
    }
}
