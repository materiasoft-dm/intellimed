@inherits LayoutComponentBase
@using IntelliMed.Web.Services
@using MudBlazor
@inject NavigationManager Navigation
@inject IAuthService AuthService
@inject IAdminService AdminService
@inject ILoggerService Logger

<MudLayout>
    @* Pure HTML/CSS slide-over nav panel — avoids MudDrawer JS interop issues in WASM *@
    @if (_drawerOpen)
    {
        @* Backdrop *@
        <div class="mdi-overlay-backdrop" @onclick="CloseDrawer" @onclick:preventDefault></div>

        @* Slide-over panel *@
        <div class="mdi-slide-panel">
            <div class="mdi-slide-header">
                <MudText Typo="Typo.h6" Class="mx-auto">IntelliMed</MudText>
            </div>
            <MudDivider />

            <MudNavMenu>
                @* Dashboard *@
                <MudNavLink Href="/" Icon="@Icons.Material.Filled.Dashboard" Match="NavLinkMatch.All">Dashboard</MudNavLink>

                <MudDivider Class="my-2" />

                @* Patients Section *@
                <MudText Typo="Typo.overline" Class="px-4 mud-text-secondary">Patients</MudText>
                <MudNavLink Href="/patients" Icon="@Icons.Material.Filled.List">Patient List</MudNavLink>
                <MudNavLink Href="/patients/add" Icon="@Icons.Material.Filled.PersonAdd">Add Patient</MudNavLink>
                <MudNavLink Href="/patients/search" Icon="@Icons.Material.Filled.Search">Find Patient</MudNavLink>

                <MudDivider Class="my-2" />

                @* Appointments Section *@
                <MudText Typo="Typo.overline" Class="px-4 mud-text-secondary">Appointments</MudText>
                <MudNavLink Href="/appointments" Icon="@Icons.Material.Filled.List">Appointment List</MudNavLink>
                <MudNavLink Href="/appointments/new" Icon="@Icons.Material.Filled.Add">New Appointment</MudNavLink>
                <MudNavLink Href="/appointments/calendar" Icon="@Icons.Material.Filled.DateRange">Calendar View</MudNavLink>

                <MudDivider Class="my-2" />

                @* Invoices Section *@
                <MudText Typo="Typo.overline" Class="px-4 mud-text-secondary">Invoices</MudText>
                <MudNavLink Href="/invoices" Icon="@Icons.Material.Filled.List">Invoice List</MudNavLink>
                <MudNavLink Href="/invoices/new" Icon="@Icons.Material.Filled.Add">New Invoice</MudNavLink>
                <MudNavLink Href="/invoices/payments" Icon="@Icons.Material.Filled.Payment">Payments</MudNavLink>

                @* Admin Section — conditional *@
                @if (_accessiblePages.Contains("admin/users") || _accessiblePages.Contains("admin/roles"))
                {
                    <MudDivider Class="my-2" />
                    <MudText Typo="Typo.overline" Class="px-4 mud-text-secondary">Administration</MudText>
                    @if (_accessiblePages.Contains("admin/users"))
                    {
                        <MudNavLink Href="/admin/users" Icon="@Icons.Material.Filled.ManageAccounts">User Management</MudNavLink>
                    }
                    @if (_accessiblePages.Contains("admin/roles"))
                    {
                        <MudNavLink Href="/admin/roles" Icon="@Icons.Material.Filled.Security">Role Configuration</MudNavLink>
                    }
                    @if (_accessiblePages.Contains("admin/audit"))
                    {
                        <MudNavLink Href="/admin/audit" Icon="@Icons.Material.Filled.Analytics">Audit Log</MudNavLink>
                    }
                    @if (_accessiblePages.Contains("admin/settings"))
                    {
                        <MudNavLink Href="/admin/settings" Icon="@Icons.Material.Filled.Settings">System Settings</MudNavLink>
                    }
                }

                <MudDivider Class="my-2" />

                @* Help Section *@
                <MudText Typo="Typo.overline" Class="px-4 mud-text-secondary">Help</MudText>
                <MudNavLink Href="/about" Icon="@Icons.Material.Filled.Info">About IntelliMed</MudNavLink>
                <MudNavLink Href="/help" Icon="@Icons.Material.Filled.Help">User Guide</MudNavLink>
            </MudNavMenu>
        </div>
    }

    @* Menu Bar — simplified: hamburger, brand, spacer, user + logout *@
    <MudAppBar Dense="true" Elevation="1" Class="mdi-menu-bar">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="ToggleDrawer" />
        <MudText Typo="Typo.h6" Class="ml-2 d-none d-sm-flex">IntelliMed</MudText>
        <MudSpacer />
        <MudText Typo="Typo.body2" Class="d-none d-sm-flex mr-2 mud-text-secondary align-self-center">@GetCurrentUser()</MudText>
        <MudIconButton Icon="@Icons.Material.Filled.Logout" Color="Color.Inherit" Edge="Edge.End" OnClick="SignOut" Title="Sign Out" />
    </MudAppBar>

    @* Main Content *@
    <MudMainContent Class="mdi-main-content">
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = false;
    private string _currentUserName = "User";
    private string _currentUserEmail = "";
    private IList<string> _currentUserRoles = new List<string>();
    private HashSet<string> _accessiblePages = new(StringComparer.OrdinalIgnoreCase);

    protected override async Task OnInitializedAsync()
    {
        await LoadCurrentUserInfo();
        await LoadCurrentUserRoles();
        await LoadAccessiblePages();
    }

    private async Task LoadCurrentUserInfo()
    {
        try
        {
            var user = await AuthService.GetCurrentUserAsync();
            if (user?.IsAuthenticated == true)
            {
                _currentUserName = user.FullName ?? user.Email ?? "User";
                _currentUserEmail = user.Email ?? "";
            }
        }
        catch
        {
            // Keep defaults
        }
    }

    private async Task LoadCurrentUserRoles()
    {
        try
        {
            var user = await AuthService.GetCurrentUserAsync();
            if (user?.IsAuthenticated == true && user.Roles != null)
            {
                _currentUserRoles = user.Roles;
            }
        }
        catch (Exception ex)
        {
            await Logger.LogErrorAsync(ex, "MainLayout.LoadCurrentUserRoles");
            _currentUserRoles = new List<string>();
        }
    }

    private async Task LoadAccessiblePages()
    {
        try
        {
            // Only call if user is authenticated
            var isAuth = await AuthService.IsAuthenticatedAsync();
            if (!isAuth) return;

            var pages = await AdminService.GetMyAccessiblePagesAsync();
            if (pages != null)
            {
                _accessiblePages = new HashSet<string>(pages, StringComparer.OrdinalIgnoreCase);
            }
        }
        catch (Exception ex)
        {
            await Logger.LogErrorAsync(ex, "MainLayout.LoadAccessiblePages");
            // Fallback: SuperAdmin/Admin get admin pages
            if (_currentUserRoles.Any(r => r == "SuperAdmin" || r == "Admin"))
            {
                _accessiblePages = new HashSet<string>(StringComparer.OrdinalIgnoreCase)
                {
                    "admin/users", "admin/roles", "admin/audit", "admin/settings"
                };
            }
        }
    }

    void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }

    void CloseDrawer()
    {
        _drawerOpen = false;
    }

    string GetCurrentUser()
    {
        return _currentUserName;
    }

    void NavigateToHome() { Navigation.NavigateTo("/"); }
    void NavigateToPatients() { Navigation.NavigateTo("/patients"); }
    void NavigateToAppointments() { Navigation.NavigateTo("/appointments"); }
    void NavigateToInvoices() { Navigation.NavigateTo("/invoices"); }
    void NavigateToUserManagement() { Navigation.NavigateTo("/admin/users"); }
    void NavigateToRoleConfiguration() { Navigation.NavigateTo("/admin/roles"); }

    async Task SignOut()
    {
        await AuthService.LogoutAsync();
        Navigation.NavigateTo("/login");
    }
}
