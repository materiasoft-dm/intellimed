@inherits LayoutComponentBase
@using IntelliMed.Core.DTOs
@using IntelliMed.Web.Services
@inject NavigationManager Navigation
@inject IAuthService AuthService
@inject IAdminService AdminService
@inject IClinicService ClinicService
@inject IClinicContextService ClinicContextService
@inject ILoggerService Logger

<div class="mdi-layout">
    @* Menu Bar — hamburger (mobile only), brand, spacer, user + logout *@
    <nav class="navbar navbar-light mdi-menu-bar px-2">
        <button class="btn btn-primary border-0 d-lg-none" @onclick="ToggleDrawer" title="Menu">
            <span class="navbar-toggler-icon"></span>
        </button>
        <button class="btn btn-primary border-0 d-none d-lg-inline-flex" @onclick="ToggleSidebarCollapsed" title="@(_sidebarCollapsed ? "Show sidebar" : "Hide sidebar")">
            <i class="bi @(_sidebarCollapsed ? "bi-chevron-right" : "bi-chevron-left")"></i>
        </button>
        <span class="navbar-brand mb-0 h6 ms-2 d-none d-sm-inline">IntelliMed</span>
        <div class="flex-grow-1"></div>

        @if (_myClinics.Count > 0)
        {
            <div class="dropdown me-2">
                <button class="btn btn-outline-secondary border-0 dropdown-toggle d-flex align-items-center gap-2" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="bi bi-building"></i>
                    <span class="d-none d-sm-inline small">@(_currentClinicName ?? "Select Clinic")</span>
                </button>
                <ul class="dropdown-menu dropdown-menu-end">
                    @foreach (var clinic in _myClinics)
                    {
                        <li>
                            <button class="dropdown-item d-flex align-items-center justify-content-between @(clinic.Id == _currentClinicId ? "active" : "")"
                                    type="button" @onclick="() => RequestSwitchClinic(clinic)">
                                @clinic.Name
                                @if (clinic.Id == _currentClinicId)
                                {
                                    <i class="bi bi-check-lg ms-2"></i>
                                }
                            </button>
                        </li>
                    }
                </ul>
            </div>
        }

        <div class="dropdown">
            <button class="btn btn-primary border-0 dropdown-toggle d-flex align-items-center gap-2" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                <i class="bi bi-person-circle"></i>
                <span class="d-none d-sm-inline small">@GetCurrentUser()</span>
            </button>
            <ul class="dropdown-menu dropdown-menu-end">
                <li><a class="dropdown-item" href="/profile"><i class="bi bi-person-gear me-2"></i>Profile Settings</a></li>
                @if (_accessiblePages.Contains("clinic-settings"))
                {
                    <li><a class="dropdown-item" href="/clinic-settings"><i class="bi bi-building me-2"></i>Clinic Settings</a></li>
                }
                @if (_accessiblePages.Contains("clinic-manager"))
                {
                    <li><a class="dropdown-item" href="/clinic-manager"><i class="bi bi-diagram-3 me-2"></i>Clinic Manager</a></li>
                }
                <li><hr class="dropdown-divider" /></li>
                <li><button class="dropdown-item" type="button" @onclick="SignOut"><i class="bi bi-box-arrow-right me-2"></i>Sign Out</button></li>
            </ul>
        </div>
    </nav>

    <div class="mdi-body">
        @* Backdrop — only rendered while the mobile drawer is open *@
        @if (_drawerOpen)
        {
            <div class="mdi-overlay-backdrop" @onclick="CloseDrawer" @onclick:preventDefault></div>
        }

        @* Sidebar — always rendered: docked column on desktop, slide-over drawer on mobile *@
        <nav class="mdi-sidebar @(_drawerOpen ? "mdi-sidebar-open" : "") @(_sidebarCollapsed ? "mdi-sidebar-collapsed" : "")">
            <div class="mdi-sidebar-header">
                <span class="mdi-logo-mark">IM</span>
                <h6 class="mb-0">IntelliMed</h6>
            </div>

            <div class="nav flex-column mdi-nav-menu">
                @* Dashboard *@
                <a href="/" class="nav-link mdi-nav-link" @onclick="CloseDrawer">
                    <i class="bi bi-speedometer2 me-2"></i> <span class="mdi-nav-label">Dashboard</span>
                </a>

                <hr class="my-2" />

                @* Clients Section *@
                <small class="text-muted px-4 text-uppercase">Clients</small>
                <a href="/clients/search" class="nav-link mdi-nav-link" @onclick="CloseDrawer">
                    <i class="bi bi-search me-2"></i> <span class="mdi-nav-label">Find Client</span>
                </a>

                <hr class="my-2" />

                @* Appointments Section *@
                <small class="text-muted px-4 text-uppercase">Appointments</small>
                <a href="/appointments" class="nav-link mdi-nav-link" @onclick="CloseDrawer">
                    <i class="bi bi-calendar-week me-2"></i> <span class="mdi-nav-label">Appointment List</span>
                </a>
                <a href="/appointments/new" class="nav-link mdi-nav-link" @onclick="CloseDrawer">
                    <i class="bi bi-plus-lg me-2"></i> <span class="mdi-nav-label">New Appointment</span>
                </a>
                <a href="/appointments/calendar" class="nav-link mdi-nav-link" @onclick="CloseDrawer">
                    <i class="bi bi-calendar3 me-2"></i> <span class="mdi-nav-label">Calendar View</span>
                </a>

                <hr class="my-2" />

                @* Invoices Section *@
                <small class="text-muted px-4 text-uppercase">Invoices</small>
                <a href="/invoices" class="nav-link mdi-nav-link" @onclick="CloseDrawer">
                    <i class="bi bi-receipt me-2"></i> <span class="mdi-nav-label">Invoice List</span>
                </a>
                <a href="/invoices/new" class="nav-link mdi-nav-link" @onclick="CloseDrawer">
                    <i class="bi bi-plus-lg me-2"></i> <span class="mdi-nav-label">New Invoice</span>
                </a>
                <a href="/invoices/payments" class="nav-link mdi-nav-link" @onclick="CloseDrawer">
                    <i class="bi bi-credit-card me-2"></i> <span class="mdi-nav-label">Payments</span>
                </a>

                @* Admin Section — conditional *@
                @if (_accessiblePages.Contains("admin/users") || _accessiblePages.Contains("admin/roles"))
                {
                    <hr class="my-2" />
                    <small class="text-muted px-4 text-uppercase">Administration</small>
                    @if (_accessiblePages.Contains("admin/users"))
                    {
                        <a href="/admin/users" class="nav-link mdi-nav-link" @onclick="CloseDrawer">
                            <i class="bi bi-person me-2"></i> <span class="mdi-nav-label">User Management</span>
                        </a>
                    }
                    @if (_accessiblePages.Contains("admin/roles"))
                    {
                        <a href="/admin/roles" class="nav-link mdi-nav-link" @onclick="CloseDrawer">
                            <i class="bi bi-shield-lock me-2"></i> <span class="mdi-nav-label">Role Configuration</span>
                        </a>
                    }
                    @if (_accessiblePages.Contains("admin/audit"))
                    {
                        <a href="/admin/audit" class="nav-link mdi-nav-link" @onclick="CloseDrawer">
                            <i class="bi bi-graph-up me-2"></i> <span class="mdi-nav-label">Audit Log</span>
                        </a>
                    }
                    @if (_accessiblePages.Contains("admin/settings"))
                    {
                        <a href="/admin/settings" class="nav-link mdi-nav-link" @onclick="CloseDrawer">
                            <i class="bi bi-gear me-2"></i> <span class="mdi-nav-label">System Settings</span>
                        </a>
                    }
                }

                <hr class="my-2" />

                @* Help Section *@
                <small class="text-muted px-4 text-uppercase">Help</small>
                <a href="/about" class="nav-link mdi-nav-link" @onclick="CloseDrawer">
                    <i class="bi bi-info-circle me-2"></i> <span class="mdi-nav-label">About IntelliMed</span>
                </a>
                <a href="/help" class="nav-link mdi-nav-link" @onclick="CloseDrawer">
                    <i class="bi bi-question-circle me-2"></i> <span class="mdi-nav-label">User Guide</span>
                </a>
            </div>
        </nav>

        @* Main Content *@
        <main class="mdi-main-content">
            <div class="container-fluid py-4">
                @Body
            </div>
        </main>
    </div>
</div>

<RadzenComponents />

@* =========================================================================
   MANDATORY CLINIC SELECTION MODAL — shown after login when the user belongs
   to more than one clinic and hasn't picked one yet for this session. Blocks
   the rest of the UI so a clinic can't be forgotten/left on a stale choice.
   ========================================================================= *@
@if (_currentClinicId == null && _myClinics.Count > 1)
{
    <div class="modal-backdrop fade show" style="display:block;"></div>
    <div class="modal fade show d-block" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Select a Clinic</h5>
                </div>
                <div class="modal-body">
                    <p>You belong to multiple clinics. Choose which one you're working in for this session.</p>
                    <div class="list-group">
                        @foreach (var clinic in _myClinics)
                        {
                            <button type="button" class="list-group-item list-group-item-action d-flex align-items-center gap-2" @onclick="() => SelectInitialClinic(clinic)">
                                <i class="bi bi-building"></i> @clinic.Name
                            </button>
                        }
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" @onclick="SignOut">
                        <i class="bi bi-box-arrow-right me-1"></i> Sign Out
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@* =========================================================================
   SWITCH CLINIC CONFIRMATION MODAL
   ========================================================================= *@
@if (_switchTargetClinic != null)
{
    <div class="modal-backdrop fade show" style="display:block;"></div>
    <div class="modal fade show d-block" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Switch Clinic</h5>
                    <button type="button" class="btn-close" @onclick="CancelSwitchClinic" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p>Switch to <strong>@_switchTargetClinic.Name</strong>? Client, appointment, and invoice lists will reload for this clinic.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CancelSwitchClinic">Cancel</button>
                    <button type="button" class="btn btn-primary" @onclick="ConfirmSwitchClinic">
                        <i class="bi bi-arrow-repeat me-1"></i> Switch
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool _drawerOpen = false;
    private bool _sidebarCollapsed = false;
    private string _currentUserName = "User";
    private string _currentUserEmail = "";
    private IList<string> _currentUserRoles = new List<string>();
    private HashSet<string> _accessiblePages = new(StringComparer.OrdinalIgnoreCase);
    private List<MyClinicDto> _myClinics = new();
    private int? _currentClinicId;
    private string? _currentClinicName;
    private MyClinicDto? _switchTargetClinic;

    protected override async Task OnInitializedAsync()
    {
        await LoadCurrentUserInfo();
        await LoadCurrentUserRoles();
        await LoadAccessiblePages();
        await LoadMyClinics();
    }

    private async Task LoadMyClinics()
    {
        try
        {
            var isAuth = await AuthService.IsAuthenticatedAsync();
            if (!isAuth) return;

            var clinics = await ClinicService.GetMyClinicsAsync();
            if (clinics == null) return;

            _myClinics = clinics;
            _currentClinicId = await ClinicContextService.GetCurrentClinicIdAsync();

            // The stored clinic (possibly left over from a different user's session on this
            // browser) must actually belong to THIS user, or every request would be scoped to
            // a clinic they don't have access to.
            if (_currentClinicId != null && !_myClinics.Any(c => c.Id == _currentClinicId))
            {
                _currentClinicId = null;
                await ClinicContextService.ClearAsync();
            }

            // Nothing selected yet: auto-select silently if the user only has one clinic.
            if (_currentClinicId == null && _myClinics.Count == 1)
            {
                _currentClinicId = _myClinics[0].Id;
                await ClinicContextService.SetCurrentClinicIdAsync(_currentClinicId.Value);
            }

            _currentClinicName = _myClinics.FirstOrDefault(c => c.Id == _currentClinicId)?.Name;
        }
        catch (Exception ex)
        {
            await Logger.LogErrorAsync(ex, "MainLayout.LoadMyClinics");
        }
    }

    private async Task SelectInitialClinic(MyClinicDto clinic)
    {
        await ClinicContextService.SetCurrentClinicIdAsync(clinic.Id);

        // Force-reload so pages that already started fetching (in parallel with this modal
        // being shown) refetch under the now-selected clinic context instead of running unscoped.
        Navigation.NavigateTo(Navigation.Uri, forceLoad: true);
    }

    private void RequestSwitchClinic(MyClinicDto clinic)
    {
        if (clinic.Id == _currentClinicId) return;
        _switchTargetClinic = clinic;
    }

    private void CancelSwitchClinic()
    {
        _switchTargetClinic = null;
    }

    private async Task ConfirmSwitchClinic()
    {
        if (_switchTargetClinic == null) return;

        await ClinicContextService.SetCurrentClinicIdAsync(_switchTargetClinic.Id);
        _switchTargetClinic = null;

        // Force-reload so every page's data refetches under the new clinic context.
        Navigation.NavigateTo(Navigation.Uri, forceLoad: true);
    }

    private async Task LoadCurrentUserInfo()
    {
        try
        {
            var user = await AuthService.GetCurrentUserAsync();
            if (user?.IsAuthenticated == true)
            {
                _currentUserName = user.FullName ?? user.Email ?? "User";
                _currentUserEmail = user.Email ?? "";
            }
        }
        catch
        {
            // Keep defaults
        }
    }

    private async Task LoadCurrentUserRoles()
    {
        try
        {
            var user = await AuthService.GetCurrentUserAsync();
            if (user?.IsAuthenticated == true && user.Roles != null)
            {
                _currentUserRoles = user.Roles;
            }
        }
        catch (Exception ex)
        {
            await Logger.LogErrorAsync(ex, "MainLayout.LoadCurrentUserRoles");
            _currentUserRoles = new List<string>();
        }
    }

    private async Task LoadAccessiblePages()
    {
        try
        {
            // Only call if user is authenticated
            var isAuth = await AuthService.IsAuthenticatedAsync();
            if (!isAuth) return;

            var pages = await AdminService.GetMyAccessiblePagesAsync();
            if (pages != null)
            {
                _accessiblePages = new HashSet<string>(pages, StringComparer.OrdinalIgnoreCase);
            }
        }
        catch (Exception ex)
        {
            await Logger.LogErrorAsync(ex, "MainLayout.LoadAccessiblePages");
            // Fallback: SuperAdmin/Admin get admin pages
            if (_currentUserRoles.Any(r => r == "SuperAdmin" || r == "Admin"))
            {
                _accessiblePages = new HashSet<string>(StringComparer.OrdinalIgnoreCase)
                {
                    "admin/users", "admin/roles", "admin/audit", "admin/settings"
                };
            }
        }
    }

    void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }

    void CloseDrawer()
    {
        _drawerOpen = false;
    }

    void ToggleSidebarCollapsed()
    {
        _sidebarCollapsed = !_sidebarCollapsed;
    }

    string GetCurrentUser()
    {
        return _currentUserName;
    }

    void NavigateToHome() { Navigation.NavigateTo("/"); }
    void NavigateToClients() { Navigation.NavigateTo("/clients"); }
    void NavigateToAppointments() { Navigation.NavigateTo("/appointments"); }
    void NavigateToInvoices() { Navigation.NavigateTo("/invoices"); }
    void NavigateToUserManagement() { Navigation.NavigateTo("/admin/users"); }
    void NavigateToRoleConfiguration() { Navigation.NavigateTo("/admin/roles"); }

    async Task SignOut()
    {
        await AuthService.LogoutAsync();
        Navigation.NavigateTo("/login");
    }
}
