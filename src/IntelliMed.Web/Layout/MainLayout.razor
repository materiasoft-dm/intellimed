@inherits LayoutComponentBase
@using IntelliMed.Web.Services
@inject NavigationManager Navigation
@inject IAuthService AuthService
@inject IAdminService AdminService
@inject ILoggerService Logger

<div class="mdi-layout">
    @* Menu Bar — hamburger (mobile only), brand, spacer, user + logout *@
    <nav class="navbar navbar-dark bg-primary mdi-menu-bar px-2">
        <button class="btn btn-primary border-0 d-lg-none" @onclick="ToggleDrawer" title="Menu">
            <span class="navbar-toggler-icon"></span>
        </button>
        <span class="navbar-brand mb-0 h6 ms-2 d-none d-sm-inline">IntelliMed</span>
        <div class="flex-grow-1"></div>
        <span class="navbar-text d-none d-sm-inline me-2 small">@GetCurrentUser()</span>
        <button class="btn btn-primary border-0" @onclick="SignOut" title="Sign Out">
            <i class="bi bi-box-arrow-right"></i>
        </button>
    </nav>

    <div class="mdi-body">
        @* Backdrop — only rendered while the mobile drawer is open *@
        @if (_drawerOpen)
        {
            <div class="mdi-overlay-backdrop" @onclick="CloseDrawer" @onclick:preventDefault></div>
        }

        @* Sidebar — always rendered: docked column on desktop, slide-over drawer on mobile *@
        <nav class="mdi-sidebar @(_drawerOpen ? "mdi-sidebar-open" : "")">
            <div class="mdi-sidebar-header">
                <h6 class="mx-auto mb-0">IntelliMed</h6>
            </div>
            <hr class="my-0" />

            <div class="nav flex-column mdi-nav-menu">
                @* Dashboard *@
                <a href="/" class="nav-link mdi-nav-link" @onclick="CloseDrawer">
                    <i class="bi bi-speedometer2 me-2"></i> Dashboard
                </a>

                <hr class="my-2" />

                @* Patients Section *@
                <small class="text-muted px-4 text-uppercase">Patients</small>
                <a href="/patients/search" class="nav-link mdi-nav-link" @onclick="CloseDrawer">
                    <i class="bi bi-search me-2"></i> Find Patient
                </a>

                <hr class="my-2" />

                @* Appointments Section *@
                <small class="text-muted px-4 text-uppercase">Appointments</small>
                <a href="/appointments" class="nav-link mdi-nav-link" @onclick="CloseDrawer">
                    <i class="bi bi-calendar-week me-2"></i> Appointment List
                </a>
                <a href="/appointments/new" class="nav-link mdi-nav-link" @onclick="CloseDrawer">
                    <i class="bi bi-plus-lg me-2"></i> New Appointment
                </a>
                <a href="/appointments/calendar" class="nav-link mdi-nav-link" @onclick="CloseDrawer">
                    <i class="bi bi-calendar3 me-2"></i> Calendar View
                </a>

                <hr class="my-2" />

                @* Invoices Section *@
                <small class="text-muted px-4 text-uppercase">Invoices</small>
                <a href="/invoices" class="nav-link mdi-nav-link" @onclick="CloseDrawer">
                    <i class="bi bi-receipt me-2"></i> Invoice List
                </a>
                <a href="/invoices/new" class="nav-link mdi-nav-link" @onclick="CloseDrawer">
                    <i class="bi bi-plus-lg me-2"></i> New Invoice
                </a>
                <a href="/invoices/payments" class="nav-link mdi-nav-link" @onclick="CloseDrawer">
                    <i class="bi bi-credit-card me-2"></i> Payments
                </a>

                @* Admin Section — conditional *@
                @if (_accessiblePages.Contains("admin/users") || _accessiblePages.Contains("admin/roles"))
                {
                    <hr class="my-2" />
                    <small class="text-muted px-4 text-uppercase">Administration</small>
                    @if (_accessiblePages.Contains("admin/users"))
                    {
                        <a href="/admin/users" class="nav-link mdi-nav-link" @onclick="CloseDrawer">
                            <i class="bi bi-person me-2"></i> User Management
                        </a>
                    }
                    @if (_accessiblePages.Contains("admin/roles"))
                    {
                        <a href="/admin/roles" class="nav-link mdi-nav-link" @onclick="CloseDrawer">
                            <i class="bi bi-shield-lock me-2"></i> Role Configuration
                        </a>
                    }
                    @if (_accessiblePages.Contains("admin/audit"))
                    {
                        <a href="/admin/audit" class="nav-link mdi-nav-link" @onclick="CloseDrawer">
                            <i class="bi bi-graph-up me-2"></i> Audit Log
                        </a>
                    }
                    @if (_accessiblePages.Contains("admin/settings"))
                    {
                        <a href="/admin/settings" class="nav-link mdi-nav-link" @onclick="CloseDrawer">
                            <i class="bi bi-gear me-2"></i> System Settings
                        </a>
                    }
                }

                <hr class="my-2" />

                @* Help Section *@
                <small class="text-muted px-4 text-uppercase">Help</small>
                <a href="/about" class="nav-link mdi-nav-link" @onclick="CloseDrawer">
                    <i class="bi bi-info-circle me-2"></i> About IntelliMed
                </a>
                <a href="/help" class="nav-link mdi-nav-link" @onclick="CloseDrawer">
                    <i class="bi bi-question-circle me-2"></i> User Guide
                </a>
            </div>
        </nav>

        @* Main Content *@
        <main class="mdi-main-content">
            <div class="container-fluid py-4">
                @Body
            </div>
        </main>
    </div>
</div>

@code {
    private bool _drawerOpen = false;
    private string _currentUserName = "User";
    private string _currentUserEmail = "";
    private IList<string> _currentUserRoles = new List<string>();
    private HashSet<string> _accessiblePages = new(StringComparer.OrdinalIgnoreCase);

    protected override async Task OnInitializedAsync()
    {
        await LoadCurrentUserInfo();
        await LoadCurrentUserRoles();
        await LoadAccessiblePages();
    }

    private async Task LoadCurrentUserInfo()
    {
        try
        {
            var user = await AuthService.GetCurrentUserAsync();
            if (user?.IsAuthenticated == true)
            {
                _currentUserName = user.FullName ?? user.Email ?? "User";
                _currentUserEmail = user.Email ?? "";
            }
        }
        catch
        {
            // Keep defaults
        }
    }

    private async Task LoadCurrentUserRoles()
    {
        try
        {
            var user = await AuthService.GetCurrentUserAsync();
            if (user?.IsAuthenticated == true && user.Roles != null)
            {
                _currentUserRoles = user.Roles;
            }
        }
        catch (Exception ex)
        {
            await Logger.LogErrorAsync(ex, "MainLayout.LoadCurrentUserRoles");
            _currentUserRoles = new List<string>();
        }
    }

    private async Task LoadAccessiblePages()
    {
        try
        {
            // Only call if user is authenticated
            var isAuth = await AuthService.IsAuthenticatedAsync();
            if (!isAuth) return;

            var pages = await AdminService.GetMyAccessiblePagesAsync();
            if (pages != null)
            {
                _accessiblePages = new HashSet<string>(pages, StringComparer.OrdinalIgnoreCase);
            }
        }
        catch (Exception ex)
        {
            await Logger.LogErrorAsync(ex, "MainLayout.LoadAccessiblePages");
            // Fallback: SuperAdmin/Admin get admin pages
            if (_currentUserRoles.Any(r => r == "SuperAdmin" || r == "Admin"))
            {
                _accessiblePages = new HashSet<string>(StringComparer.OrdinalIgnoreCase)
                {
                    "admin/users", "admin/roles", "admin/audit", "admin/settings"
                };
            }
        }
    }

    void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }

    void CloseDrawer()
    {
        _drawerOpen = false;
    }

    string GetCurrentUser()
    {
        return _currentUserName;
    }

    void NavigateToHome() { Navigation.NavigateTo("/"); }
    void NavigateToPatients() { Navigation.NavigateTo("/patients"); }
    void NavigateToAppointments() { Navigation.NavigateTo("/appointments"); }
    void NavigateToInvoices() { Navigation.NavigateTo("/invoices"); }
    void NavigateToUserManagement() { Navigation.NavigateTo("/admin/users"); }
    void NavigateToRoleConfiguration() { Navigation.NavigateTo("/admin/roles"); }

    async Task SignOut()
    {
        await AuthService.LogoutAsync();
        Navigation.NavigateTo("/login");
    }
}
