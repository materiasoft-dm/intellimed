@page "/"
@using IntelliMed.Web.Services
@using MudBlazor
@inject IAuthService AuthService
@inject NavigationManager Navigation
@layout MainLayout

<PageTitle>IntelliMed - Dashboard</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    <MudText Typo="Typo.h4" Class="mb-4">Welcome to IntelliMed</MudText>
    
    <MudGrid>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4" Elevation="2">
                <MudIcon Icon="@Icons.Material.Filled.People" Color="Color.Primary" Size="Size.Large" />
                <MudText Typo="Typo.h5" Class="mt-2">Patients</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">Manage patient records</MudText>
            </MudPaper>
        </MudItem>
        
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4" Elevation="2">
                <MudIcon Icon="@Icons.Material.Filled.CalendarMonth" Color="Color.Success" Size="Size.Large" />
                <MudText Typo="Typo.h5" Class="mt-2">Appointments</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">Schedule and view appointments</MudText>
            </MudPaper>
        </MudItem>
        
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4" Elevation="2">
                <MudIcon Icon="@Icons.Material.Filled.Receipt" Color="Color.Warning" Size="Size.Large" />
                <MudText Typo="Typo.h5" Class="mt-2">Invoices</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">Manage billing and invoices</MudText>
            </MudPaper>
        </MudItem>
        
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4" Elevation="2">
                <MudIcon Icon="@Icons.Material.Filled.Settings" Color="Color.Info" Size="Size.Large" />
                <MudText Typo="Typo.h5" Class="mt-2">Settings</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">Configure your practice</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudPaper Class="mt-6 pa-4" Elevation="2">
        <MudText Typo="Typo.h6" Class="mb-3">Quick Actions</MudText>
        <MudStack Row="true" Spacing="2">
            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.PersonAdd">
                New Patient
            </MudButton>
            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Add">
                New Appointment
            </MudButton>
            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Receipt">
                Create Invoice
            </MudButton>
        </MudStack>
    </MudPaper>

    <MudPaper Class="mt-6 pa-4" Elevation="2">
        <MudText Typo="Typo.h6" Class="mb-3">Recent Activity</MudText>
        <MudText Typo="Typo.body1" Color="Color.Secondary">
            No recent activity to display.
        </MudText>
    </MudPaper>

    <div class="mt-4">
        <MudButton Variant="Variant.Text" 
                   Color="Color.Secondary" 
                   OnClick="HandleLogout"
                   StartIcon="@Icons.Material.Filled.Logout">
            Sign Out
        </MudButton>
    </div>
</MudContainer>

@code {
    protected override async Task OnInitializedAsync()
    {
        // Redirect to login if not authenticated
        if (!await AuthService.IsAuthenticatedAsync())
        {
            Navigation.NavigateTo("/login");
        }
    }

    private async Task HandleLogout()
    {
        await AuthService.LogoutAsync();
        Navigation.NavigateTo("/login");
    }
}
