@page "/"
@layout MainLayout
@using IntelliMed.Core.DTOs
@using IntelliMed.Core.Entities
@using IntelliMed.Web.Services
@inject IAuthService AuthService
@inject IAdminService AdminService
@inject IClientService ClientService
@inject ILoggerService Logger
@inject IJSRuntime JS

<PageTitle>IntelliMed - Dashboard</PageTitle>

<h3 class="mb-1">Welcome, @_currentUserName</h3>
<p class="text-muted mb-4">Here's what's happening across your practice today.</p>

@if (_isLoading)
{
    <div class="text-center py-5">
        <span class="spinner-border spinner-border-sm text-primary me-2"></span>
        Loading dashboard...
    </div>
}
else
{
    @* Stat tiles *@
    <div class="row g-3 mb-3">
        <div class="col-sm-6 col-lg-3">
            <div class="card h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <span class="stat-icon-badge stat-icon-badge--blue"><i class="bi bi-people"></i></span>
                    <div>
                        <div class="stat-tile-value">@_totalClients</div>
                        <div class="text-muted small">Total Clients</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3">
            <div class="card h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <span class="stat-icon-badge stat-icon-badge--green"><i class="bi bi-person-check"></i></span>
                    <div>
                        <div class="stat-tile-value">@_activeClients</div>
                        <div class="text-muted small">Active Clients</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3">
            <div class="card h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <span class="stat-icon-badge stat-icon-badge--amber"><i class="bi bi-person-plus"></i></span>
                    <div>
                        <div class="stat-tile-value">@_newThisWeek</div>
                        <div class="text-muted small">New This Week</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3">
            <div class="card h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <span class="stat-icon-badge stat-icon-badge--purple"><i class="bi bi-archive"></i></span>
                    <div>
                        <div class="stat-tile-value">@_archivedClients</div>
                        <div class="text-muted small">Archived</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-3">
        <div class="col-lg-7">
            <div class="card h-100">
                <div class="card-body">
                    <h6 class="mb-1">Clients by Account Type</h6>
                    <p class="text-muted small mb-3">Distribution across all registered clients.</p>
                    @if (_totalClients == 0)
                    {
                        <p class="text-muted small">No clients yet — add one to see this chart.</p>
                    }
                    else
                    {
                        <div style="height: 260px;">
                            <canvas id="clientsByAccountTypeChart"></canvas>
                        </div>
                    }
                </div>
            </div>
        </div>
        <div class="col-lg-5">
            <div class="card h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-1">
                        <h6 class="mb-0">Recent Clients</h6>
                        <a href="/clients/search" class="small text-decoration-none">View all</a>
                    </div>
                    <p class="text-muted small mb-3">Most recently registered.</p>
                    @if (_recentClients.Count == 0)
                    {
                        <p class="text-muted small">No clients yet.</p>
                    }
                    else
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var c in _recentClients)
                            {
                                <li class="list-group-item px-0 d-flex justify-content-between align-items-center">
                                    <span>@c.FullName</span>
                                    <span class="text-muted small">@c.CreatedAt.ToString("dd/MM/yyyy")</span>
                                </li>
                            }
                        </ul>
                    }
                </div>
            </div>
        </div>
    </div>

    @* Quick links *@
    <div class="row g-3">
        <div class="col-sm-6 col-lg-3">
            <a href="/clients/search" class="text-decoration-none">
                <div class="card h-100">
                    <div class="card-body d-flex align-items-center gap-3">
                        <span class="stat-icon-badge stat-icon-badge--blue"><i class="bi bi-search"></i></span>
                        <div>
                            <div class="fw-semibold">Find Client</div>
                            <div class="text-muted small">Search and manage clients</div>
                        </div>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-sm-6 col-lg-3">
            <a href="/clients/add" class="text-decoration-none">
                <div class="card h-100">
                    <div class="card-body d-flex align-items-center gap-3">
                        <span class="stat-icon-badge stat-icon-badge--green"><i class="bi bi-plus-lg"></i></span>
                        <div>
                            <div class="fw-semibold">Add Client</div>
                            <div class="text-muted small">Register a new client</div>
                        </div>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-sm-6 col-lg-3">
            <a href="/appointments" class="text-decoration-none">
                <div class="card h-100">
                    <div class="card-body d-flex align-items-center gap-3">
                        <span class="stat-icon-badge stat-icon-badge--amber"><i class="bi bi-calendar-week"></i></span>
                        <div>
                            <div class="fw-semibold">Appointments</div>
                            <div class="text-muted small">Schedule and review visits</div>
                        </div>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-sm-6 col-lg-3">
            <a href="/invoices" class="text-decoration-none">
                <div class="card h-100">
                    <div class="card-body d-flex align-items-center gap-3">
                        <span class="stat-icon-badge stat-icon-badge--purple"><i class="bi bi-receipt"></i></span>
                        <div>
                            <div class="fw-semibold">Invoices</div>
                            <div class="text-muted small">Billing and payments</div>
                        </div>
                    </div>
                </div>
            </a>
        </div>
        @if (_showAdminCard)
        {
            <div class="col-sm-6 col-lg-3">
                <a href="/admin/users" class="text-decoration-none">
                    <div class="card h-100">
                        <div class="card-body d-flex align-items-center gap-3">
                            <span class="stat-icon-badge stat-icon-badge--blue"><i class="bi bi-shield-lock"></i></span>
                            <div>
                                <div class="fw-semibold">Administration</div>
                                <div class="text-muted small">Users and role access</div>
                            </div>
                        </div>
                    </div>
                </a>
            </div>
        }
    </div>
}

@code {
    private string _currentUserName = "User";
    private bool _showAdminCard;
    private bool _isLoading = true;

    private int _totalClients;
    private int _activeClients;
    private int _archivedClients;
    private int _newThisWeek;
    private List<ClientDto> _recentClients = new();
    private List<(string Label, int Count)> _accountTypeCounts = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var user = await AuthService.GetCurrentUserAsync();
            if (user?.IsAuthenticated == true)
            {
                _currentUserName = user.FullName ?? user.Email ?? "User";
            }
        }
        catch
        {
            // Keep default greeting
        }

        try
        {
            var pages = await AdminService.GetMyAccessiblePagesAsync();
            _showAdminCard = pages is not null &&
                (pages.Contains("admin/users", StringComparer.OrdinalIgnoreCase) ||
                 pages.Contains("admin/roles", StringComparer.OrdinalIgnoreCase));
        }
        catch (Exception ex)
        {
            await Logger.LogErrorAsync(ex, "Home.OnInitializedAsync");
        }

        await LoadClientStatsAsync();
        _isLoading = false;
    }

    private async Task LoadClientStatsAsync()
    {
        try
        {
            var result = await ClientService.SearchClientsAsync(new ClientSearchDto
            {
                Page = 1,
                PageSize = 1000,
                IncludeArchived = true
            });

            var clients = result.Items.ToList();
            _totalClients = clients.Count;
            _activeClients = clients.Count(c => c.IsActive);
            _archivedClients = clients.Count(c => !c.IsActive);

            var weekAgo = DateTime.UtcNow.AddDays(-7);
            _newThisWeek = clients.Count(c => c.CreatedAt >= weekAgo);

            _recentClients = clients
                .OrderByDescending(c => c.CreatedAt)
                .Take(5)
                .ToList();

            _accountTypeCounts = clients
                .GroupBy(c => c.AccountType)
                .Select(g => (Label: g.Key.ToString(), Count: g.Count()))
                .OrderByDescending(x => x.Count)
                .ToList();
        }
        catch (Exception ex)
        {
            await Logger.LogErrorAsync(ex, "Home.LoadClientStatsAsync");
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_isLoading && _totalClients > 0)
        {
            var labels = _accountTypeCounts.Select(x => x.Label).ToArray();
            var data = _accountTypeCounts.Select(x => x.Count).ToArray();
            await JS.InvokeVoidAsync("IntelliMedRenderBarChart", "clientsByAccountTypeChart", labels, data, "#4272d7");
        }
    }
}
