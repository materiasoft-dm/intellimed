@page "/admin/users"
@layout MainLayout
@using System.ComponentModel.DataAnnotations
@using IntelliMed.Core.DTOs
@using IntelliMed.Web.Services
@inject IAdminService AdminService
@inject IAuthService AuthService
@inject IClinicService ClinicService
@inject NavigationManager Navigation

<PageTitle>User Management - IntelliMed</PageTitle>

<h4 class="mb-4">User Management</h4>

@* Toolbar *@
<div class="card mb-4">
    <div class="card-body d-flex align-items-center justify-content-between">
        <span class="d-flex align-items-center">
            <i class="bi bi-people me-2"></i>
            Total Users: @(_users?.Count ?? 0)
        </span>
        <button class="btn btn-primary" @onclick="OpenCreateDialog">
            <i class="bi bi-plus-lg me-1"></i> Add User
        </button>
    </div>
</div>

@* Loading State *@
@if (_isLoading)
{
    <div class="card text-center py-5">
        <div class="card-body">
            <span class="spinner-border spinner-border-sm text-primary me-2"></span>
            Loading users...
        </div>
    </div>
}

@* Error State *@
@if (!string.IsNullOrEmpty(_error))
{
    <div class="alert alert-danger d-flex align-items-center mb-4">
        <i class="bi bi-exclamation-triangle me-1"></i> @_error
        <button class="btn btn-outline-danger btn-sm ms-auto" @onclick="LoadUsers">Retry</button>
    </div>
}

@* Toast container for success/error messages *@
<div class="toast-container position-fixed bottom-0 end-0 p-3" aria-live="polite" aria-atomic="true">
    @if (_toastMessage != null)
    {
        <div class="toast show align-items-center @(_toastIsError ? "text-bg-danger" : "text-bg-success") border-0" role="alert">
            <div class="d-flex">
                <div class="toast-body">
                    <i class="bi @(_toastIsError ? "bi-exclamation-triangle" : "bi-check-circle-fill") me-1"></i> @_toastMessage
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" @onclick="DismissToast" aria-label="Close"></button>
            </div>
        </div>
    }
</div>

@* Users Table *@
@if (!_isLoading && _users != null)
{
    <div class="card">
        <div class="card-header d-flex align-items-center justify-content-between">
            <h6 class="mb-0">Users</h6>
            <div class="input-group" style="max-width: 300px;">
                <span class="input-group-text"><i class="bi bi-search"></i></span>
                <input type="text" class="form-control form-control-sm" placeholder="Search users..."
                       @bind="_filter" @bind:event="oninput" />
            </div>
        </div>
        <div class="table-responsive">
            <table class="table table-hover table-striped table-sm mb-0">
                <thead class="table-light">
                    <tr>
                        <th @onclick="() => ToggleSort(nameof(UserDto.FullName))" style="cursor:pointer">
                            Name @SortIndicator(nameof(UserDto.FullName))
                        </th>
                        <th @onclick="() => ToggleSort(nameof(UserDto.Email))" style="cursor:pointer">
                            Email @SortIndicator(nameof(UserDto.Email))
                        </th>
                        <th @onclick="() => ToggleSort(nameof(UserDto.Roles))" style="cursor:pointer">
                            Roles @SortIndicator(nameof(UserDto.Roles))
                        </th>
                        <th @onclick="() => ToggleSort(nameof(UserDto.IsActive))" style="cursor:pointer">
                            Status @SortIndicator(nameof(UserDto.IsActive))
                        </th>
                        <th @onclick="() => ToggleSort(nameof(UserDto.LastLoginAt))" style="cursor:pointer">
                            Last Login @SortIndicator(nameof(UserDto.LastLoginAt))
                        </th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        var filtered = FilteredAndSortedUsers();
                        var paged = Paginate(filtered);
                    }
                    @foreach (var user in paged)
                    {
                        <tr>
                            <td>
                                <i class="bi bi-person me-2 text-muted"></i>
                                @user.FullName
                            </td>
                            <td>@user.Email</td>
                            <td>
                                @foreach (var role in user.Roles.OrderBy(r => r))
                                {
                                    <span class="badge @GetRoleBadgeClass(role) me-1 mb-1">@role</span>
                                }
                                @if (!user.Roles.Any())
                                {
                                    <span class="badge bg-secondary">No Roles</span>
                                }
                            </td>
                            <td>
                                @if (user.IsActive)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Inactive</span>
                                }
                            </td>
                            <td>
                                @(user.LastLoginAt?.ToString("yyyy-MM-dd HH:mm") ?? "Never")
                            </td>
                            <td class="text-end">
                                <button class="btn btn-sm btn-outline-primary me-1" title="Edit"
                                        @onclick="() => OpenEditDialog(user)"><i class="bi bi-pencil"></i></button>
                                <button class="btn btn-sm btn-outline-warning me-1" title="Reset Password"
                                        @onclick="() => OpenResetPasswordDialog(user)"><i class="bi bi-key"></i></button>
                                <button class="btn btn-sm btn-outline-danger" title="Deactivate"
                                        @onclick="() => OpenDeleteDialog(user)"><i class="bi bi-trash"></i></button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        @if (filtered.Count == 0)
        {
            <div class="card-body text-center text-muted py-4">
                No users found matching your search.
            </div>
        }
        @* Pagination *@
        @if (filtered.Count > _pageSize)
        {
            <div class="card-footer d-flex justify-content-between align-items-center">
                <span class="text-muted small">
                    Showing @((_currentPage - 1) * _pageSize + 1)-@Math.Min(_currentPage * _pageSize, filtered.Count) of @filtered.Count
                </span>
                <nav>
                    <ul class="pagination pagination-sm mb-0">
                        <li class="page-item @(_currentPage <= 1 ? "disabled" : "")">
                            <button class="page-link" @onclick="() => _currentPage = 1" disabled="@(_currentPage <= 1)">««</button>
                        </li>
                        <li class="page-item @(_currentPage <= 1 ? "disabled" : "")">
                            <button class="page-link" @onclick="() => _currentPage--" disabled="@(_currentPage <= 1)">«</button>
                        </li>
                        @for (int i = 1; i <= _totalPages; i++)
                        {
                            <li class="page-item @(i == _currentPage ? "active" : "")">
                                <button class="page-link" @onclick="() => _currentPage = i">@i</button>
                            </li>
                        }
                        <li class="page-item @(_currentPage >= _totalPages ? "disabled" : "")">
                            <button class="page-link" @onclick="() => _currentPage++" disabled="@(_currentPage >= _totalPages)">»</button>
                        </li>
                        <li class="page-item @(_currentPage >= _totalPages ? "disabled" : "")">
                            <button class="page-link" @onclick="() => _currentPage = _totalPages" disabled="@(_currentPage >= _totalPages)">»»</button>
                        </li>
                    </ul>
                </nav>
            </div>
        }
    </div>
}

@* =========================================================================
   CREATE / EDIT USER MODAL
   ========================================================================= *@
@if (_dialogVisible)
{
    <div class="modal-backdrop fade show" style="display:block;"></div>
    <div class="modal fade show d-block" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(_isEditing ? "Edit User" : "Create New User")</h5>
                    <button type="button" class="btn-close" @onclick="CloseDialog" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <EditForm Model="@_dialogModel" OnValidSubmit="SaveUser" FormName="userDialogForm">
                        <DataAnnotationsValidator />
                        <ValidationSummary class="text-danger small mb-3" />

                        <div class="mb-3">
                            <label class="form-label">First Name <span class="text-danger">*</span></label>
                            <InputText @bind-Value="_dialogModel.FirstName" class="form-control" />
                            <ValidationMessage For="() => _dialogModel.FirstName" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Last Name <span class="text-danger">*</span></label>
                            <InputText @bind-Value="_dialogModel.LastName" class="form-control" />
                            <ValidationMessage For="() => _dialogModel.LastName" />
                        </div>

                        @if (!_isEditing)
                        {
                            <div class="mb-3">
                                <label class="form-label">Email Address <span class="text-danger">*</span></label>
                                <InputText @bind-Value="_dialogModel.Email" class="form-control" type="email" />
                                <ValidationMessage For="() => _dialogModel.Email" />
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Password <span class="text-danger">*</span></label>
                                <div class="input-group">
                                    <InputText @bind-Value="_dialogModel.Password"
                                               type="@(_showDialogPassword ? "text" : "password")"
                                               class="form-control" />
                                    <button type="button" class="btn btn-outline-secondary"
                                            @onclick="() => _showDialogPassword = !_showDialogPassword">
                                        <i class="bi @(_showDialogPassword ? "bi-eye-slash" : "bi-eye")"></i>
                                    </button>
                                </div>
                                <div class="form-text">Min 8 chars: upper, lower, digit, special</div>
                                <ValidationMessage For="() => _dialogModel.Password" />
                            </div>
                        }

                        @* Role Assignment *@
                        <h6 class="mt-4 mb-2">Role Assignment</h6>
                        <div class="card bg-light">
                            <div class="card-body">
                                @if (_availableRoles != null)
                                {
                                    foreach (var role in _availableRoles.OrderBy(r => r.Name))
                                    {
                                        var roleName = role.Name;
                                        <div class="form-check mb-2">
                                            <input class="form-check-input" type="checkbox"
                                                   checked="@_dialogModel.IsRoleSelected(roleName)"
                                                   @onchange="(ChangeEventArgs e) => _dialogModel.ToggleRole(roleName, (bool)e.Value!)"
                                                   id="role_@roleName" />
                                            <label class="form-check-label" for="role_@roleName">
                                                @role.Name
                                            </label>
                                            <i class="bi bi-info-circle ms-1 text-muted" title="@role.Description" style="cursor:help"></i>
                                        </div>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted small">Loading roles...</span>
                                }
                            </div>
                        </div>

                        @* Clinic Assignment *@
                        <h6 class="mt-4 mb-2">Clinic Assignment</h6>
                        <div class="card bg-light">
                            <div class="card-body">
                                @if (_availableClinics != null)
                                {
                                    @if (_availableClinics.Count == 0)
                                    {
                                        <span class="text-muted small">No clinics configured yet.</span>
                                    }
                                    foreach (var clinic in _availableClinics.OrderBy(c => c.Name))
                                    {
                                        var clinicId = clinic.Id;
                                        <div class="form-check mb-2">
                                            <input class="form-check-input" type="checkbox"
                                                   checked="@_dialogModel.IsClinicSelected(clinicId)"
                                                   @onchange="(ChangeEventArgs e) => _dialogModel.ToggleClinic(clinicId, (bool)e.Value!)"
                                                   id="clinic_@clinicId" />
                                            <label class="form-check-label" for="clinic_@clinicId">
                                                @clinic.Name
                                            </label>
                                        </div>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted small">Loading clinics...</span>
                                }
                            </div>
                        </div>

                        @if (_isEditing)
                        {
                            <div class="form-check form-switch mt-4">
                                <input class="form-check-input" type="checkbox" role="switch"
                                       checked="@_dialogModel.IsActive"
                                       @onchange="(ChangeEventArgs e) => _dialogModel.IsActive = (bool)e.Value!"
                                       id="activeSwitch" />
                                <label class="form-check-label" for="activeSwitch">Active Account</label>
                            </div>
                        }

                        <div class="modal-footer px-0 pb-0">
                            <button type="button" class="btn btn-secondary" @onclick="CloseDialog">Cancel</button>
                            <button type="submit" class="btn btn-primary" disabled="@_dialogSaving">
                                @if (_dialogSaving)
                                {
                                    <span class="spinner-border spinner-border-sm me-2"></span>
                                    <span>Saving...</span>
                                }
                                else
                                {
                                    <span>@(_isEditing ? "Save Changes" : "Create User")</span>
                                }
                            </button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

@* =========================================================================
   RESET PASSWORD MODAL
   ========================================================================= *@
@if (_resetPasswordVisible)
{
    <div class="modal-backdrop fade show" style="display:block;"></div>
    <div class="modal fade show d-block" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Reset Password</h5>
                    <button type="button" class="btn-close" @onclick="() => _resetPasswordVisible = false" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p>
                        Reset password for <strong>@(_resetPasswordUser?.FullName)</strong> (@(_resetPasswordUser?.Email))
                    </p>
                    <div class="mb-3">
                        <label class="form-label">New Password <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <input type="@(_showResetPassword ? "text" : "password")"
                                   class="form-control"
                                   @bind="_resetPasswordValue"
                                   @bind:event="oninput" />
                            <button type="button" class="btn btn-outline-secondary"
                                    @onclick="() => _showResetPassword = !_showResetPassword">
                                <i class="bi @(_showResetPassword ? "bi-eye-slash" : "bi-eye")"></i>
                            </button>
                        </div>
                        <div class="form-text">Min 8 chars: upper, lower, digit, special</div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => _resetPasswordVisible = false">Cancel</button>
                    <button type="button" class="btn btn-warning"
                            @onclick="ResetPassword"
                            disabled="@(string.IsNullOrWhiteSpace(_resetPasswordValue) || _resetPasswordSaving)">
                        @if (_resetPasswordSaving)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                            <span>Resetting...</span>
                        }
                        else
                        {
                            <span>Reset Password</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@* =========================================================================
   DELETE CONFIRMATION MODAL
   ========================================================================= *@
@if (_deleteDialogVisible)
{
    <div class="modal-backdrop fade show" style="display:block;"></div>
    <div class="modal fade show d-block" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Deactivate User</h5>
                    <button type="button" class="btn-close" @onclick="() => _deleteDialogVisible = false" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-warning d-flex align-items-center mb-3">
                        <i class="bi bi-exclamation-triangle me-1"></i> This will deactivate the user account. The user will no longer be able to log in.
                        No data is permanently deleted.
                    </div>
                    <p>
                        Are you sure you want to deactivate <strong>@(_deleteUser?.FullName)</strong> (@(_deleteUser?.Email))?
                    </p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => _deleteDialogVisible = false">Cancel</button>
                    <button type="button" class="btn btn-danger"
                            @onclick="DeleteUser"
                            disabled="@_deleteSaving">
                        @if (_deleteSaving)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                            <span>Deactivating...</span>
                        }
                        else
                        {
                            <span>Deactivate User</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    // =========================================================================
    // DATA STATE
    // =========================================================================
    private List<UserDto>? _users;
    private List<RoleDto>? _availableRoles;
    private List<MyClinicDto>? _availableClinics;
    private string _filter = string.Empty;
    private bool _isLoading = true;
    private string? _error;

    // =========================================================================
    // SORTING STATE
    // =========================================================================
    private string? _sortColumn;
    private bool _sortAscending = true;

    // =========================================================================
    // PAGINATION STATE
    // =========================================================================
    private int _currentPage = 1;
    private int _pageSize = 10;
    private int _totalPages => Math.Max(1, (int)Math.Ceiling((double)FilteredAndSortedUsers().Count / _pageSize));

    // =========================================================================
    // TOAST STATE
    // =========================================================================
    private string? _toastMessage;
    private bool _toastIsError;

    // =========================================================================
    // CREATE / EDIT MODAL STATE
    // =========================================================================
    private bool _dialogVisible;
    private bool _isEditing;
    private bool _dialogSaving;
    private bool _showDialogPassword;
    private UserDialogModel _dialogModel = new();
    private UserDto? _editingUser;

    // =========================================================================
    // RESET PASSWORD MODAL STATE
    // =========================================================================
    private bool _resetPasswordVisible;
    private bool _resetPasswordSaving;
    private bool _showResetPassword;
    private UserDto? _resetPasswordUser;
    private string _resetPasswordValue = string.Empty;

    // =========================================================================
    // DELETE MODAL STATE
    // =========================================================================
    private bool _deleteDialogVisible;
    private bool _deleteSaving;
    private UserDto? _deleteUser;

    // =========================================================================
    // LIFECYCLE
    // =========================================================================
    protected override async Task OnInitializedAsync()
    {
        await LoadUsers();
        await LoadRoles();
        await LoadClinics();
    }

    private async Task LoadClinics()
    {
        try
        {
            _availableClinics = await ClinicService.GetLookupAsync();
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"LoadClinics error: {ex.Message}");
        }
    }

    private async Task LoadUsers()
    {
        _isLoading = true;
        _error = null;
        StateHasChanged();

        try
        {
            _users = await AdminService.GetUsersAsync();
            if (_users == null)
            {
                _error = "Failed to load users. The API may be unavailable or you may not have admin permissions.";
            }
        }
        catch (Exception ex)
        {
            _error = $"Error loading users: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoadRoles()
    {
        try
        {
            _availableRoles = await AdminService.GetRolesAsync();
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"LoadRoles error: {ex.Message}");
        }
    }

    // =========================================================================
    // FILTERING, SORTING, PAGINATION
    // =========================================================================
    private List<UserDto> FilteredAndSortedUsers()
    {
        if (_users == null) return new();

        var filtered = _users.AsEnumerable();

        if (!string.IsNullOrWhiteSpace(_filter))
        {
            filtered = filtered.Where(u =>
                (u.FullName?.Contains(_filter, StringComparison.OrdinalIgnoreCase) ?? false)
                || (u.Email?.Contains(_filter, StringComparison.OrdinalIgnoreCase) ?? false));
        }

        if (_sortColumn != null)
        {
            filtered = _sortColumn switch
            {
                nameof(UserDto.FullName) => _sortAscending
                    ? filtered.OrderBy(u => u.FullName)
                    : filtered.OrderByDescending(u => u.FullName),
                nameof(UserDto.Email) => _sortAscending
                    ? filtered.OrderBy(u => u.Email)
                    : filtered.OrderByDescending(u => u.Email),
                nameof(UserDto.Roles) => _sortAscending
                    ? filtered.OrderBy(u => string.Join(",", u.Roles.OrderBy(r => r)))
                    : filtered.OrderByDescending(u => string.Join(",", u.Roles.OrderBy(r => r))),
                nameof(UserDto.IsActive) => _sortAscending
                    ? filtered.OrderBy(u => u.IsActive)
                    : filtered.OrderByDescending(u => u.IsActive),
                nameof(UserDto.LastLoginAt) => _sortAscending
                    ? filtered.OrderBy(u => u.LastLoginAt ?? DateTime.MinValue)
                    : filtered.OrderByDescending(u => u.LastLoginAt ?? DateTime.MinValue),
                _ => filtered
            };
        }

        return filtered.ToList();
    }

    private List<UserDto> Paginate(List<UserDto> users)
    {
        // Reset page if out of bounds
        if (_currentPage > _totalPages) _currentPage = _totalPages;
        return users.Skip((_currentPage - 1) * _pageSize).Take(_pageSize).ToList();
    }

    private void ToggleSort(string column)
    {
        if (_sortColumn == column)
        {
            _sortAscending = !_sortAscending;
        }
        else
        {
            _sortColumn = column;
            _sortAscending = true;
        }
        _currentPage = 1;
    }

    private string SortIndicator(string column)
    {
        if (_sortColumn != column) return "";
        return _sortAscending ? "▲" : "▼";
    }

    // =========================================================================
    // TOAST
    // =========================================================================
    private void ShowToast(string message, bool isError = false)
    {
        _toastMessage = message;
        _toastIsError = isError;
        StateHasChanged();
    }

    private void DismissToast()
    {
        _toastMessage = null;
    }

    // =========================================================================
    // ROLE BADGE HELPER
    // =========================================================================
    private static string GetRoleBadgeClass(string role) => role switch
    {
        "SuperAdmin" => "bg-danger",
        "Admin" => "bg-warning text-dark",
        "Doctor" => "bg-primary",
        "Nurse" => "bg-success",
        "Receptionist" => "bg-info text-dark",
        _ => "bg-secondary"
    };

    // =========================================================================
    // CREATE MODAL
    // =========================================================================
    private void OpenCreateDialog()
    {
        _isEditing = false;
        _editingUser = null;
        _dialogModel = new UserDialogModel { IsEditing = false };
        _dialogSaving = false;
        _showDialogPassword = false;
        _dialogVisible = true;
    }

    // =========================================================================
    // EDIT MODAL
    // =========================================================================
    private void OpenEditDialog(UserDto user)
    {
        _isEditing = true;
        _editingUser = user;
        _dialogModel = new UserDialogModel
        {
            IsEditing = true,
            FirstName = user.FirstName,
            LastName = user.LastName,
            Email = user.Email,
            IsActive = user.IsActive,
            SelectedRoles = user.Roles.ToList(),
            SelectedClinics = user.ClinicIds.ToList()
        };
        _dialogSaving = false;
        _showDialogPassword = false;
        _dialogVisible = true;
    }

    private void CloseDialog()
    {
        _dialogVisible = false;
        _editingUser = null;
    }

    // =========================================================================
    // SAVE USER (CREATE OR UPDATE)
    // =========================================================================
    private async Task SaveUser()
    {
        _dialogSaving = true;
        StateHasChanged();

        try
        {
            if (_isEditing && _editingUser != null)
            {
                var request = new UpdateUserRequest
                {
                    FirstName = _dialogModel.FirstName,
                    LastName = _dialogModel.LastName,
                    IsActive = _dialogModel.IsActive,
                    Roles = _dialogModel.SelectedRoles,
                    ClinicIds = _dialogModel.SelectedClinics
                };

                var result = await AdminService.UpdateUserAsync(_editingUser.Id, request);

                if (result?.Success == true)
                {
                    ShowToast("User updated successfully.");
                    _dialogVisible = false;
                    await LoadUsers();
                }
                else
                {
                    ShowToast(result?.Message ?? "Failed to update user.", true);
                }
            }
            else
            {
                var request = new CreateUserRequest
                {
                    Email = _dialogModel.Email,
                    Password = _dialogModel.Password,
                    FirstName = _dialogModel.FirstName,
                    LastName = _dialogModel.LastName,
                    Roles = _dialogModel.SelectedRoles,
                    ClinicIds = _dialogModel.SelectedClinics
                };

                var result = await AdminService.CreateUserAsync(request);

                if (result?.Success == true)
                {
                    ShowToast("User created successfully.");
                    _dialogVisible = false;
                    await LoadUsers();
                }
                else
                {
                    ShowToast(result?.Message ?? "Failed to create user.", true);
                }
            }
        }
        catch (Exception ex)
        {
            ShowToast($"Error: {ex.Message}", true);
        }
        finally
        {
            _dialogSaving = false;
        }
    }

    // =========================================================================
    // RESET PASSWORD MODAL
    // =========================================================================
    private void OpenResetPasswordDialog(UserDto user)
    {
        _resetPasswordUser = user;
        _resetPasswordValue = string.Empty;
        _resetPasswordSaving = false;
        _showResetPassword = false;
        _resetPasswordVisible = true;
    }

    private async Task ResetPassword()
    {
        if (_resetPasswordUser == null || string.IsNullOrWhiteSpace(_resetPasswordValue))
            return;

        _resetPasswordSaving = true;
        StateHasChanged();

        try
        {
            var request = new ResetPasswordRequest { NewPassword = _resetPasswordValue };
            var result = await AdminService.ResetPasswordAsync(_resetPasswordUser.Id, request);

            if (result?.Success == true)
            {
                ShowToast("Password reset successfully.");
                _resetPasswordVisible = false;
            }
            else
            {
                ShowToast(result?.Message ?? "Failed to reset password.", true);
            }
        }
        catch (Exception ex)
        {
            ShowToast($"Error: {ex.Message}", true);
        }
        finally
        {
            _resetPasswordSaving = false;
        }
    }

    // =========================================================================
    // DELETE (DEACTIVATE) MODAL
    // =========================================================================
    private void OpenDeleteDialog(UserDto user)
    {
        _deleteUser = user;
        _deleteSaving = false;
        _deleteDialogVisible = true;
    }

    private async Task DeleteUser()
    {
        if (_deleteUser == null) return;

        _deleteSaving = true;
        StateHasChanged();

        try
        {
            var result = await AdminService.DeleteUserAsync(_deleteUser.Id);

            if (result?.Success == true)
            {
                ShowToast("User deactivated successfully.");
                _deleteDialogVisible = false;
                await LoadUsers();
            }
            else
            {
                ShowToast(result?.Message ?? "Failed to deactivate user.", true);
            }
        }
        catch (Exception ex)
        {
            ShowToast($"Error: {ex.Message}", true);
        }
        finally
        {
            _deleteSaving = false;
        }
    }

    // =========================================================================
    // DIALOG MODEL CLASS
    // =========================================================================
    private class UserDialogModel : IValidatableObject
    {
        [Required]
        public string FirstName { get; set; } = string.Empty;

        [Required]
        public string LastName { get; set; } = string.Empty;

        [Required, EmailAddress]
        public string Email { get; set; } = string.Empty;

        /// <summary>Only validated as required when creating a new user — see Validate() below.</summary>
        public string Password { get; set; } = string.Empty;

        /// <summary>Set by the caller before validation runs; true when editing an existing user (password not shown/required).</summary>
        public bool IsEditing { get; set; }

        public bool IsActive { get; set; } = true;

        public List<string> SelectedRoles { get; set; } = new();
        public List<int> SelectedClinics { get; set; } = new();

        public bool IsRoleSelected(string role)
        {
            return SelectedRoles.Contains(role);
        }

        public void ToggleRole(string role, bool isChecked)
        {
            if (isChecked && !SelectedRoles.Contains(role))
                SelectedRoles.Add(role);
            else if (!isChecked && SelectedRoles.Contains(role))
                SelectedRoles.Remove(role);
        }

        public bool IsClinicSelected(int clinicId)
        {
            return SelectedClinics.Contains(clinicId);
        }

        public void ToggleClinic(int clinicId, bool isChecked)
        {
            if (isChecked && !SelectedClinics.Contains(clinicId))
                SelectedClinics.Add(clinicId);
            else if (!isChecked && SelectedClinics.Contains(clinicId))
                SelectedClinics.Remove(clinicId);
        }

        public IEnumerable<ValidationResult> Validate(ValidationContext validationContext)
        {
            if (!IsEditing && Password.Length < 8)
            {
                yield return new ValidationResult(
                    "Password must be at least 8 characters.",
                    new[] { nameof(Password) });
            }
        }
    }
}