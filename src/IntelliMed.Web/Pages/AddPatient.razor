@page "/patients/add"
@page "/patients/edit/{Id:int}"
@layout MainLayout
@using IntelliMed.Core.DTOs
@using IntelliMed.Core.Entities
@using IntelliMed.Web.Services
@using Microsoft.AspNetCore.Components.Forms
@inject IPatientService PatientService
@inject IPatientAddressService AddressService
@inject IPatientReferralService ReferralService
@inject IPatientCompensationClaimService CompensationClaimService
@inject IPatientOccupationService OccupationService
@inject IPatientFamilyService FamilyService
@inject IPatientUdfValueService UdfValueService
@inject IUdfDefinitionService UdfDefinitionService
@inject IHealthFundService HealthFundService
@inject NavigationManager NavManager

<PageTitle>@(Id.HasValue ? "Edit Patient" : "Add Patient") - IntelliMed</PageTitle>

@if (_isLoading)
{
    <div class="card text-center py-3">
        <div class="card-body py-2">
            <span class="spinner-border spinner-border-sm text-primary me-2"></span>
            Loading patient...
        </div>
    </div>
}
else
{
    <div class="patient-edit-page">
    <div class="d-flex align-items-center justify-content-between mb-1">
        <h5 class="mb-0 small">🩺 @(Id.HasValue ? $"Edit Patient — {_model.FirstName} {_model.LastName}" : "New Patient")</h5>
        @if (!string.IsNullOrEmpty(_statusMessage))
        {
            <span class="small @(_statusIsError ? "text-danger" : "text-success")">@_statusMessage</span>
        }
    </div>

    <EditForm Model="_model" OnValidSubmit="HandleSaveAsync">
        <DataAnnotationsValidator />

        <div class="row g-1 mb-1">
            @* ===================== PERSONAL ===================== *@
            <div class="col-lg-6">
                <div class="card h-100">
                    <div class="card-header py-1"><strong>Personal</strong></div>
                    <div class="card-body py-1">
                        <div class="row g-1">
                            <div class="col-6">
                                <label class="form-label small mb-0">Type</label>
                                <InputSelect @bind-Value="_model.Type" class="form-select form-select-sm">
                                    <option value="@PatientTypeEnum.Person">Person</option>
                                    <option value="@PatientTypeEnum.Organisation">Organisation</option>
                                </InputSelect>
                            </div>
                            <div class="col-6"></div>
                            <div class="col-6">
                                <label class="form-label small mb-0">@(_model.Type == PatientTypeEnum.Organisation ? "Family/Org" : "Surname")</label>
                                <InputText @bind-Value="_model.LastName" class="form-control form-control-sm" />
                            </div>
                            <div class="col-6">
                                <label class="form-label small mb-0">Given</label>
                                <InputText @bind-Value="_model.FirstName" class="form-control form-control-sm" />
                            </div>
                            <div class="col-6">
                                <label class="form-label small mb-0">Middle</label>
                                <InputText @bind-Value="_model.MiddleName" class="form-control form-control-sm" />
                            </div>
                            <div class="col-6">
                                <label class="form-label small mb-0">Preferred</label>
                                <InputText @bind-Value="_model.PreferredName" class="form-control form-control-sm" />
                            </div>
                            <div class="col-6">
                                <label class="form-label small mb-0">Maiden</label>
                                <InputText @bind-Value="_model.MaidenName" class="form-control form-control-sm" />
                            </div>
                            <div class="col-6">
                                <label class="form-label small mb-0">Title</label>
                                <InputText @bind-Value="_model.Title" class="form-control form-control-sm" />
                            </div>
                            <div class="col-6">
                                <label class="form-label small mb-0">Gender</label>
                                <InputSelect @bind-Value="_model.Gender" class="form-select form-select-sm">
                                    <option value="@GenderEnum.Unspecified">Unspecified</option>
                                    <option value="@GenderEnum.Male">Male</option>
                                    <option value="@GenderEnum.Female">Female</option>
                                    <option value="@GenderEnum.Other">Other</option>
                                </InputSelect>
                            </div>
                            <div class="col-6">
                                <label class="form-label small mb-0">D.O.B</label>
                                <InputDate @bind-Value="_model.DateOfBirth" class="form-control form-control-sm" />
                            </div>
                            <div class="col-6">
                                <label class="form-label small mb-0">Accuracy</label>
                                <InputSelect @bind-Value="_model.DobAccuracy" class="form-select form-select-sm">
                                    <option value="@DobAccuracyEnum.Day">Day - Accurate</option>
                                    <option value="@DobAccuracyEnum.Month">Month - Accurate</option>
                                    <option value="@DobAccuracyEnum.Year">Year - Accurate</option>
                                    <option value="@DobAccuracyEnum.Estimated">Estimated</option>
                                </InputSelect>
                            </div>
                            <div class="col-6">
                                <label class="form-label small mb-0">Age</label>
                                <input class="form-control form-control-sm" value="@CalculateAge(_model.DateOfBirth)" disabled />
                            </div>
                            <div class="col-6">
                                <label class="form-label small mb-0">P.O.B</label>
                                <InputText @bind-Value="_model.PlaceOfBirth" class="form-control form-control-sm" />
                            </div>
                            <div class="col-6 d-flex align-items-end">
                                <div class="form-check">
                                    <InputCheckbox @bind-Value="_model.InterpreterRequired" class="form-check-input" id="chkInterpreter" />
                                    <label class="form-check-label small" for="chkInterpreter">Interpreter?</label>
                                </div>
                            </div>
                            <div class="col-6">
                                <label class="form-label small mb-0">Language</label>
                                <InputText @bind-Value="_model.InterpreterLanguage" class="form-control form-control-sm" disabled="@(!_model.InterpreterRequired)" />
                            </div>
                            <div class="col-6">
                                <label class="form-label small mb-0">Marital Status</label>
                                <InputSelect @bind-Value="_model.MaritalStatus" class="form-select form-select-sm">
                                    <option value="">-</option>
                                    <option value="@MaritalStatusEnum.Single">Single</option>
                                    <option value="@MaritalStatusEnum.Married">Married</option>
                                    <option value="@MaritalStatusEnum.DeFacto">De Facto</option>
                                    <option value="@MaritalStatusEnum.Divorced">Divorced</option>
                                    <option value="@MaritalStatusEnum.Widowed">Widowed</option>
                                    <option value="@MaritalStatusEnum.Separated">Separated</option>
                                    <option value="@MaritalStatusEnum.Unknown">Unknown</option>
                                </InputSelect>
                            </div>
                            <div class="col-6">
                                <label class="form-label small mb-0">Ethnicity</label>
                                <InputText @bind-Value="_model.Ethnicity" class="form-control form-control-sm" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            @* ===================== ENTITLEMENT ===================== *@
            <div class="col-lg-6">
                <div class="card h-100">
                    <div class="card-header py-1"><strong>Entitlement</strong></div>
                    <div class="card-body py-1">
                        <div class="row g-1">
                            <div class="col-6">
                                <label class="form-label small mb-0">Medicare#</label>
                                <InputText @bind-Value="_model.MedicareNumber" class="form-control form-control-sm" />
                            </div>
                            <div class="col-3">
                                <label class="form-label small mb-0">Ref</label>
                                <InputText @bind-Value="_model.MedicarePosition" class="form-control form-control-sm" />
                            </div>
                            <div class="col-3">
                                <label class="form-label small mb-0">EXP</label>
                                <InputDate @bind-Value="_model.MedicareExpiryDate" class="form-control form-control-sm" />
                            </div>
                            <div class="col-9">
                                <label class="form-label small mb-0">Veteran#</label>
                                <InputText @bind-Value="_model.DvaNumber" class="form-control form-control-sm" />
                            </div>
                            <div class="col-3">
                                <label class="form-label small mb-0">EXP</label>
                                <InputDate @bind-Value="_model.DvaExpiryDate" class="form-control form-control-sm" />
                            </div>
                            <div class="col-9">
                                <label class="form-label small mb-0">Pension/HCC</label>
                                <InputText @bind-Value="_model.PensionNumber" class="form-control form-control-sm" />
                            </div>
                            <div class="col-3">
                                <label class="form-label small mb-0">EXP</label>
                                <InputDate @bind-Value="_model.PensionExpiryDate" class="form-control form-control-sm" />
                            </div>
                            <div class="col-6">
                                <label class="form-label small mb-0">Status</label>
                                <InputText @bind-Value="_model.EntitlementStatus" class="form-control form-control-sm" />
                            </div>
                            <div class="col-6">
                                <label class="form-label small mb-0">Safety Net</label>
                                <InputText @bind-Value="_model.SafetyNetNumber" class="form-control form-control-sm" />
                            </div>
                            <div class="col-6">
                                <label class="form-label small mb-0">ATSI</label>
                                <InputSelect @bind-Value="_model.AtsiStatus" class="form-select form-select-sm">
                                    <option value="@AtsiStatusEnum.NotAsked">Not Asked</option>
                                    <option value="@AtsiStatusEnum.AboriginalOnly">Aboriginal</option>
                                    <option value="@AtsiStatusEnum.TorresStraitIslanderOnly">Torres Strait Islander</option>
                                    <option value="@AtsiStatusEnum.Both">Both</option>
                                    <option value="@AtsiStatusEnum.NeitherAboriginalNorTorresStraitIslander">Neither</option>
                                </InputSelect>
                            </div>
                            <div class="col-6 d-flex flex-column justify-content-end">
                                <div class="form-check">
                                    <InputCheckbox @bind-Value="_model.MedicareIncentiveEligible" class="form-check-input" id="chkIncentive" />
                                    <label class="form-check-label small" for="chkIncentive">Medicare+ Incentive</label>
                                </div>
                                <div class="form-check">
                                    <InputCheckbox @bind-Value="_model.CtgCoPaymentRelief" class="form-check-input" id="chkCtg" />
                                    <label class="form-check-label small" for="chkCtg">CTG CoPayment Relief</label>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-1 mb-1">
            @* ===================== ADDRESSES ===================== *@
            <div class="col-lg-6">
                <div class="card h-100">
                    <div class="card-header py-1">
                        <ul class="nav nav-tabs card-header-tabs">
                            <li class="nav-item"><a class="nav-link @(_addressTab == "Residential" ? "active" : "")" href="javascript:void(0)" @onclick="@(() => _addressTab = "Residential")">Residential</a></li>
                            <li class="nav-item"><a class="nav-link @(_addressTab == "Postal" ? "active" : "")" href="javascript:void(0)" @onclick="@(() => _addressTab = "Postal")">Postal</a></li>
                            <li class="nav-item"><a class="nav-link @(_addressTab == "Other" ? "active" : "")" href="javascript:void(0)" @onclick="@(() => _addressTab = "Other")">Other Addresses</a></li>
                        </ul>
                    </div>
                    <div class="card-body py-1">
                        @if (_addressTab == "Residential")
                        {
                            <div class="row g-1">
                                <div class="col-12">
                                    <label class="form-label small mb-0">Address</label>
                                    <InputText @bind-Value="_model.Address" class="form-control form-control-sm" />
                                </div>
                                <div class="col-6">
                                    <label class="form-label small mb-0">Suburb</label>
                                    <InputText @bind-Value="_model.Suburb" class="form-control form-control-sm" />
                                </div>
                                <div class="col-3">
                                    <label class="form-label small mb-0">Postcode</label>
                                    <InputText @bind-Value="_model.Postcode" class="form-control form-control-sm" />
                                </div>
                                <div class="col-3">
                                    <label class="form-label small mb-0">State</label>
                                    <InputText @bind-Value="_model.State" class="form-control form-control-sm" />
                                </div>
                            </div>
                        }
                        else
                        {
                            var addrType = _addressTab == "Postal" ? PatientAddressType.Postal : PatientAddressType.Other;
                            var addr = GetOrCreateAddress(addrType);
                            <div class="row g-1">
                                <div class="col-12">
                                    <label class="form-label small mb-0">Address</label>
                                    <input class="form-control form-control-sm" @bind="addr.AddressLine1" />
                                </div>
                                <div class="col-6">
                                    <label class="form-label small mb-0">Suburb</label>
                                    <input class="form-control form-control-sm" @bind="addr.Suburb" />
                                </div>
                                <div class="col-3">
                                    <label class="form-label small mb-0">Postcode</label>
                                    <input class="form-control form-control-sm" @bind="addr.Postcode" />
                                </div>
                                <div class="col-3">
                                    <label class="form-label small mb-0">State</label>
                                    <input class="form-control form-control-sm" @bind="addr.State" />
                                </div>
                                <div class="col-6">
                                    <label class="form-label small mb-0">Type</label>
                                    <input class="form-control form-control-sm" @bind="addr.AddressSubType" />
                                </div>
                                <div class="col-6">
                                    <label class="form-label small mb-0">Community</label>
                                    <input class="form-control form-control-sm" @bind="addr.Community" />
                                </div>
                                <div class="col-6 d-flex align-items-end">
                                    <div class="form-check">
                                        <input type="checkbox" class="form-check-input" id="chkSendMedicare" @bind="addr.SendToMedicare" />
                                        <label class="form-check-label small" for="chkSendMedicare">Send To Medicare</label>
                                    </div>
                                </div>
                                <div class="col-6 text-end align-self-end">
                                    <button type="button" class="btn btn-sm btn-outline-primary" @onclick="@(() => SaveAddressAsync(addr))" disabled="@(!Id.HasValue)">Save Address</button>
                                </div>
                                @if (!Id.HasValue)
                                {
                                    <div class="col-12"><span class="text-muted small">Save the patient first to add this address.</span></div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>

            @* ===================== CONTACT DETAILS ===================== *@
            <div class="col-lg-6">
                <div class="card h-100">
                    <div class="card-header py-1"><strong>Contact Details</strong></div>
                    <div class="card-body py-1">
                        <div class="row g-1">
                            <div class="col-6">
                                <label class="form-label small mb-0">Home Phone</label>
                                <InputText @bind-Value="_model.Phone" class="form-control form-control-sm" />
                            </div>
                            <div class="col-6">
                                <label class="form-label small mb-0">B.H</label>
                                <InputText @bind-Value="_model.BusinessHoursPhone" class="form-control form-control-sm" />
                            </div>
                            <div class="col-6">
                                <label class="form-label small mb-0">Mobile Phone</label>
                                <InputText @bind-Value="_model.MobilePhone" class="form-control form-control-sm" />
                            </div>
                            <div class="col-6">
                                <label class="form-label small mb-0">Fax</label>
                                <InputText @bind-Value="_model.FaxNumber" class="form-control form-control-sm" />
                            </div>
                            <div class="col-12">
                                <label class="form-label small mb-0">Email</label>
                                <InputText @bind-Value="_model.Email" class="form-control form-control-sm" />
                            </div>
                            <div class="col-12 d-flex gap-3">
                                <div class="form-check">
                                    <InputCheckbox @bind-Value="_model.AcceptSms" class="form-check-input" id="chkSms" />
                                    <label class="form-check-label small" for="chkSms">Accept SMS</label>
                                </div>
                                <div class="form-check">
                                    <InputCheckbox @bind-Value="_model.AcceptEmail" class="form-check-input" id="chkEmail" />
                                    <label class="form-check-label small" for="chkEmail">Accept Email</label>
                                </div>
                                <div class="form-check">
                                    <InputCheckbox @bind-Value="_model.AcceptOnlineAppointments" class="form-check-input" id="chkOnlineAppt" />
                                    <label class="form-check-label small" for="chkOnlineAppt">Accept Online Appt.</label>
                                </div>
                            </div>
                            <div class="col-6">
                                <label class="form-label small mb-0">Note</label>
                                <InputTextArea @bind-Value="_model.Notes" class="form-control form-control-sm" rows="2" />
                            </div>
                            <div class="col-6">
                                <label class="form-label small mb-0">Warnings</label>
                                <InputTextArea @bind-Value="_model.Warnings" class="form-control form-control-sm" rows="2" />
                            </div>
                            <div class="col-6">
                                <label class="form-label small mb-0">Next of Kin</label>
                                <InputText @bind-Value="_model.NextOfKinName" class="form-control form-control-sm" />
                            </div>
                            <div class="col-6">
                                <label class="form-label small mb-0">N.O.K Phone</label>
                                <InputText @bind-Value="_model.NextOfKinPhone" class="form-control form-control-sm" />
                            </div>
                            <div class="col-6">
                                <label class="form-label small mb-0">Emergency</label>
                                <InputText @bind-Value="_model.EmergencyContactName" class="form-control form-control-sm" disabled="@_model.SameAsNextOfKin" />
                            </div>
                            <div class="col-6">
                                <label class="form-label small mb-0">Emergency Phone</label>
                                <InputText @bind-Value="_model.EmergencyContactPhone" class="form-control form-control-sm" disabled="@_model.SameAsNextOfKin" />
                            </div>
                            <div class="col-6 d-flex align-items-end">
                                <div class="form-check">
                                    <InputCheckbox @bind-Value="_model.SameAsNextOfKin" class="form-check-input" id="chkSameAsNok" />
                                    <label class="form-check-label small" for="chkSameAsNok">Same as Next of Kin</label>
                                </div>
                            </div>
                            <div class="col-6 d-flex align-items-end">
                                <div class="form-check">
                                    <InputCheckbox @bind-Value="_model.AcceptSmsMarketing" class="form-check-input" id="chkSmsMkt" />
                                    <label class="form-check-label small" for="chkSmsMkt">Accept SMS Marketing</label>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-1 mb-1">
            @* ===================== HEALTH FUND ===================== *@
            <div class="col-lg-4">
                <div class="card h-100">
                    <div class="card-header py-1"><strong>Health Fund</strong></div>
                    <div class="card-body py-1">
                        <div class="row g-1">
                            <div class="col-12">
                                <label class="form-label small mb-0">Fund Id</label>
                                <InputSelect @bind-Value="_model.HealthFundId" class="form-select form-select-sm">
                                    <option value="">-- None --</option>
                                    @foreach (var fund in _healthFunds)
                                    {
                                        <option value="@fund.Id">@fund.Code - @fund.Name</option>
                                    }
                                </InputSelect>
                            </div>
                            <div class="col-6">
                                <label class="form-label small mb-0">Member#</label>
                                <InputText @bind-Value="_model.HealthFundNumber" class="form-control form-control-sm" />
                            </div>
                            <div class="col-6">
                                <label class="form-label small mb-0">Ref</label>
                                <InputText @bind-Value="_model.HealthFundRef" class="form-control form-control-sm" />
                            </div>
                            <div class="col-6">
                                <label class="form-label small mb-0">Alias Family</label>
                                <InputText @bind-Value="_model.HealthFundAliasFamily" class="form-control form-control-sm" />
                            </div>
                            <div class="col-6">
                                <label class="form-label small mb-0">Alias First</label>
                                <InputText @bind-Value="_model.HealthFundAliasFirst" class="form-control form-control-sm" />
                            </div>
                            <div class="col-6">
                                <label class="form-label small mb-0">Joined</label>
                                <InputDate @bind-Value="_model.HealthFundJoinDate" class="form-control form-control-sm" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            @* ===================== ACCOUNT ===================== *@
            <div class="col-lg-4">
                <div class="card h-100">
                    <div class="card-header py-1"><strong>Account</strong></div>
                    <div class="card-body py-1">
                        <div class="row g-1">
                            <div class="col-6">
                                <label class="form-label small mb-0">Acc. Type</label>
                                <InputSelect @bind-Value="_model.AccountType" class="form-select form-select-sm">
                                    <option value="@AccountTypeEnum.PrivatePatient">Private Patient</option>
                                    <option value="@AccountTypeEnum.Concession">Concession</option>
                                    <option value="@AccountTypeEnum.Pensioner">Pensioner</option>
                                    <option value="@AccountTypeEnum.Veteran">Veteran</option>
                                    <option value="@AccountTypeEnum.WorkCover">WorkCover</option>
                                    <option value="@AccountTypeEnum.Tac">TAC</option>
                                    <option value="@AccountTypeEnum.BulkBill">Bulk Bill</option>
                                    <option value="@AccountTypeEnum.Other">Other</option>
                                </InputSelect>
                            </div>
                            <div class="col-6">
                                <label class="form-label small mb-0">Fee Rate</label>
                                <InputText @bind-Value="_model.FeeRateCode" class="form-control form-control-sm" />
                            </div>
                            <div class="col-12">
                                <label class="form-label small mb-0">Payer</label>
                                <div class="input-group input-group-sm">
                                    <input class="form-control form-control-sm" value="@_model.PayerName" readonly placeholder="No payer selected" />
                                    <button type="button" class="btn btn-outline-secondary" @onclick="OpenPayerPicker">Find</button>
                                    @if (_model.PayerPatientId.HasValue)
                                    {
                                        <button type="button" class="btn btn-outline-secondary" @onclick="ClearPayer">x</button>
                                    }
                                </div>
                            </div>
                            <div class="col-12">
                                <label class="form-label small mb-0">Acc. Name</label>
                                <InputText @bind-Value="_model.AccountName" class="form-control form-control-sm" />
                            </div>
                            <div class="col-6">
                                <label class="form-label small mb-0">BSB</label>
                                <InputText @bind-Value="_model.AccountBsb" class="form-control form-control-sm" />
                            </div>
                            <div class="col-6">
                                <label class="form-label small mb-0">Acc#</label>
                                <InputText @bind-Value="_model.AccountNumber" class="form-control form-control-sm" />
                            </div>
                            <div class="col-12">
                                <div class="form-check">
                                    <InputCheckbox @bind-Value="_model.UseMedicareRegisteredBankAccount" class="form-check-input" id="chkBankMedicare" />
                                    <label class="form-check-label small" for="chkBankMedicare">Use bank account registered with Medicare</label>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            @* ===================== FILE ===================== *@
            <div class="col-lg-4">
                <div class="card h-100">
                    <div class="card-header py-1"><strong>File</strong></div>
                    <div class="card-body py-1">
                        <div class="row g-1">
                            <div class="col-6">
                                <label class="form-label small mb-0">File#</label>
                                <InputText @bind-Value="_model.FileNumber" class="form-control form-control-sm" />
                            </div>
                            <div class="col-6">
                                <label class="form-label small mb-0">UR No</label>
                                <InputText @bind-Value="_model.UrNumber" class="form-control form-control-sm" />
                            </div>
                            <div class="col-6">
                                <label class="form-label small mb-0">Created</label>
                                <input class="form-control form-control-sm" value="@_model.CreatedAtDisplay" disabled />
                            </div>
                            <div class="col-6 d-flex align-items-end">
                                <div class="form-check">
                                    <input type="checkbox" class="form-check-input" id="chkDeceased" checked="@_model.Deceased" @onchange="@(e => _model.Deceased = (bool)(e.Value ?? false))" />
                                    <label class="form-check-label small" for="chkDeceased">Deceased</label>
                                </div>
                            </div>
                            <div class="col-6">
                                <label class="form-label small mb-0">Provider (Practitioner ID)</label>
                                <InputNumber @bind-Value="_model.ProviderId" class="form-control form-control-sm" />
                            </div>
                            <div class="col-6">
                                <label class="form-label small mb-0">Last Seen Date</label>
                                <InputDate @bind-Value="_model.LastSeenDate" class="form-control form-control-sm" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @* ===================== BOTTOM TAB STRIP ===================== *@
        <div class="card mb-1">
            <div class="card-header py-1">
                <ul class="nav nav-tabs card-header-tabs">
                    @foreach (var tab in _bottomTabs)
                    {
                        <li class="nav-item">
                            <a class="nav-link @(_activeBottomTab == tab ? "active" : "")" href="javascript:void(0)" @onclick="@(() => _activeBottomTab = tab)">@tab</a>
                        </li>
                    }
                </ul>
            </div>
            <div class="card-body py-1" style="min-height: 150px;">
                @if (!Id.HasValue)
                {
                    <div class="text-muted small">Save the patient first to manage @_activeBottomTab.</div>
                }
                else if (_activeBottomTab == "Referrals")
                {
                    @RenderReferralsTab()
                }
                else if (_activeBottomTab == "WC/TAC")
                {
                    @RenderCompensationClaimsTab()
                }
                else if (_activeBottomTab == "Family")
                {
                    @RenderFamilyTab()
                }
                else if (_activeBottomTab == "Occupations")
                {
                    @RenderOccupationsTab()
                }
                else if (_activeBottomTab == "eHealth")
                {
                    @RenderEHealthTab()
                }
                else if (_activeBottomTab == "Lifecard")
                {
                    @RenderLifecardTab()
                }
                else if (_activeBottomTab == "UDF")
                {
                    @RenderUdfTab()
                }
            </div>
        </div>

        @* ===================== BOTTOM ACTION BAR ===================== *@
        <div class="d-flex justify-content-between align-items-center">
            <div class="d-flex gap-1">
                <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="ShowPatientVerification">Patient Verification</button>
                <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="ShowPrintLabel">Print Label</button>
                <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="StartNewFamily" disabled="@(!Id.HasValue)">New Family</button>
            </div>
            <div class="d-flex gap-1">
                <button type="submit" class="btn btn-sm btn-primary" disabled="@_isSaving">💾 Save</button>
                <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="GoToList">Close</button>
            </div>
        </div>
    </EditForm>

    @if (_underConstructionMessage != null)
    {
        <div class="modal d-block" tabindex="-1" style="background: rgba(0,0,0,0.4);">
            <div class="modal-dialog modal-dialog-centered modal-sm">
                <div class="modal-content">
                    <div class="modal-header py-2">
                        <h6 class="modal-title">@_underConstructionMessage</h6>
                        <button type="button" class="btn-close" @onclick="@(() => _underConstructionMessage = null)"></button>
                    </div>
                    <div class="modal-body py-2 small text-muted">
                        This feature is under construction and will be available in a future update.
                    </div>
                    <div class="modal-footer py-2">
                        <button type="button" class="btn btn-sm btn-primary" @onclick="@(() => _underConstructionMessage = null)">OK</button>
                    </div>
                </div>
            </div>
        </div>
    }

    @if (_showNewFamilyModal)
    {
        <div class="modal d-block" tabindex="-1" style="background: rgba(0,0,0,0.4);">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header py-2">
                        <h6 class="modal-title">New Family Member</h6>
                        <button type="button" class="btn-close" @onclick="@(() => _showNewFamilyModal = false)"></button>
                    </div>
                    <div class="modal-body">
                        <div class="row g-2">
                            <div class="col-6">
                                <label class="form-label small mb-0">Surname</label>
                                <input class="form-control form-control-sm" @bind="_newFamilyLastName" />
                            </div>
                            <div class="col-6">
                                <label class="form-label small mb-0">Given</label>
                                <input class="form-control form-control-sm" @bind="_newFamilyFirstName" />
                            </div>
                            <div class="col-12">
                                <label class="form-label small mb-0">Relationship</label>
                                <input class="form-control form-control-sm" placeholder="e.g. Spouse, Child, Parent" @bind="_newFamilyRelationship" />
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer py-2">
                        <button type="button" class="btn btn-sm btn-secondary" @onclick="@(() => _showNewFamilyModal = false)">Cancel</button>
                        <button type="button" class="btn btn-sm btn-primary" @onclick="CreateNewFamilyMemberAsync">Create</button>
                    </div>
                </div>
            </div>
        </div>
    }

    @if (_showPayerPickerModal)
    {
        <div class="modal d-block" tabindex="-1" style="background: rgba(0,0,0,0.4);">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header py-2">
                        <h6 class="modal-title">Find Payer</h6>
                        <button type="button" class="btn-close" @onclick="@(() => _showPayerPickerModal = false)"></button>
                    </div>
                    <div class="modal-body">
                        <input class="form-control form-control-sm mb-2" placeholder="Search by name..."
                               @bind="_payerSearchTerm" @bind:event="oninput" @bind:after="SearchPayerCandidatesAsync" />
                        <div style="max-height: 300px; overflow-y: auto;">
                            @if (_payerSearchResults.Count == 0)
                            {
                                <div class="text-muted small">No matches.</div>
                            }
                            else
                            {
                                <ul class="list-group">
                                    @foreach (var candidate in _payerSearchResults)
                                    {
                                        <li class="list-group-item list-group-item-action" style="cursor:pointer" @onclick="@(() => SelectPayer(candidate))">
                                            @candidate.FullName <span class="text-muted small">(@candidate.DateOfBirth.ToString("dd/MM/yyyy"))</span>
                                        </li>
                                    }
                                </ul>
                            }
                        </div>
                    </div>
                    <div class="modal-footer py-2">
                        <button type="button" class="btn btn-sm btn-secondary" @onclick="@(() => _showPayerPickerModal = false)">Cancel</button>
                    </div>
                </div>
            </div>
        </div>
    }
    </div>
}

@code {
    [Parameter] public int? Id { get; set; }
    [SupplyParameterFromQuery] public string? Type { get; set; }

    private class PatientFormModel : UpdatePatientDto
    {
        public DateTime CreatedAt { get; set; }
        public string CreatedAtDisplay => CreatedAt == default ? "-" : CreatedAt.ToString("dd/MM/yyyy");
    }

    private PatientFormModel _model = new();
    private bool _isLoading = true;
    private bool _isSaving;
    private string? _statusMessage;
    private bool _statusIsError;
    private string? _underConstructionMessage;
    private List<HealthFundDto> _healthFunds = new();

    private string _addressTab = "Residential";
    private Dictionary<PatientAddressType, PatientAddressDto> _addressCache = new();

    private static readonly string[] _bottomTabs = { "Referrals", "WC/TAC", "Family", "Occupations", "eHealth", "Lifecard", "UDF" };
    private string _activeBottomTab = "Referrals";

    // Referrals
    private List<PatientReferralDto> _referrals = new();
    private bool _includeArchivedReferrals;
    private bool _showReferralModal;
    private CreatePatientReferralDto _referralForm = new();
    private int? _editingReferralId;

    // Compensation claims (WC/TAC)
    private List<PatientCompensationClaimDto> _claims = new();
    private bool _includeArchivedClaims;
    private bool _showClaimModal;
    private CreatePatientCompensationClaimDto _claimForm = new();
    private int? _editingClaimId;

    // Occupations
    private List<PatientOccupationDto> _occupations = new();
    private bool _includeArchivedOccupations;
    private bool _showOccupationModal;
    private CreatePatientOccupationDto _occupationForm = new();
    private int? _editingOccupationId;

    // Family
    private List<PatientFamilyRelationshipDto> _familyRelationships = new();
    private bool _showNewFamilyModal;
    private string _newFamilyFirstName = string.Empty;
    private string _newFamilyLastName = string.Empty;
    private string _newFamilyRelationship = string.Empty;

    // Payer picker
    private bool _showPayerPickerModal;
    private string _payerSearchTerm = string.Empty;
    private List<PatientDto> _payerSearchResults = new();

    // UDF
    private List<PatientUserDefinedFieldValueDto> _udfValues = new();
    private List<UserDefinedFieldTypeDto> _udfDefinitions = new();
    private bool _showUdfModal;
    private int? _udfFieldTypeId;
    private string? _udfValueText;
    private string? _udfNoteText;
    private int? _editingUdfValueId;

    protected override async Task OnInitializedAsync()
    {
        _healthFunds = (await HealthFundService.GetAllActiveAsync()).ToList();
    }

    protected override async Task OnParametersSetAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        if (Id.HasValue)
        {
            var patient = await PatientService.GetPatientByIdAsync(Id.Value);
            if (patient != null)
            {
                _model = MapToFormModel(patient);
                await LoadAddressesAsync();
                await LoadTabDataAsync();
            }
        }
        else
        {
            var type = string.Equals(Type, "Organisation", StringComparison.OrdinalIgnoreCase)
                ? PatientTypeEnum.Organisation
                : PatientTypeEnum.Person;
            _model = new PatientFormModel { DateOfBirth = DateTime.Today.AddYears(-30), Type = type };
        }
        _isLoading = false;
    }

    private async Task LoadAddressesAsync()
    {
        if (!Id.HasValue) return;
        var addresses = await AddressService.GetByPatientIdAsync(Id.Value);
        _addressCache = addresses.ToDictionary(a => a.AddressType);
    }

    private async Task LoadTabDataAsync()
    {
        if (!Id.HasValue) return;
        _referrals = (await ReferralService.GetByPatientIdAsync(Id.Value)).ToList();
        _claims = (await CompensationClaimService.GetByPatientIdAsync(Id.Value)).ToList();
        _occupations = (await OccupationService.GetByPatientIdAsync(Id.Value)).ToList();
        _familyRelationships = (await FamilyService.GetByPatientIdAsync(Id.Value)).ToList();
        _udfValues = (await UdfValueService.GetByPatientIdAsync(Id.Value)).ToList();
        _udfDefinitions = (await UdfDefinitionService.GetAllActiveAsync()).ToList();
    }

    private static int CalculateAge(DateTime dateOfBirth)
    {
        var today = DateTime.Today;
        var age = today.Year - dateOfBirth.Year;
        if (dateOfBirth.Date > today.AddYears(-age)) age--;
        return age;
    }

    private void SetStatus(string message, bool isError)
    {
        _statusMessage = message;
        _statusIsError = isError;
    }

    private void GoToList() => NavManager.NavigateTo("/patients");
    private void ShowPatientVerification() => _underConstructionMessage = "Patient Verification";
    private void ShowPrintLabel() => _underConstructionMessage = "Print Label";
    private void StartNewFamily()
    {
        _newFamilyFirstName = string.Empty;
        _newFamilyLastName = string.Empty;
        _newFamilyRelationship = string.Empty;
        _showNewFamilyModal = true;
    }

    private async Task CreateNewFamilyMemberAsync()
    {
        if (!Id.HasValue) return;
        var createDto = new CreatePatientDto
        {
            FirstName = _newFamilyFirstName,
            LastName = _newFamilyLastName,
            DateOfBirth = DateTime.Today
        };
        var newId = await PatientService.CreatePatientAsync(createDto);
        if (newId.HasValue)
        {
            await FamilyService.CreateAsync(new CreatePatientFamilyRelationshipDto
            {
                PatientId = Id.Value,
                RelativePatientId = newId.Value,
                RelationshipType = _newFamilyRelationship
            });
            _familyRelationships = (await FamilyService.GetByPatientIdAsync(Id.Value)).ToList();
            _showNewFamilyModal = false;
        }
        else
        {
            SetStatus("Failed to create family member.", true);
        }
    }

    private void OpenPayerPicker()
    {
        _payerSearchTerm = string.Empty;
        _payerSearchResults = new();
        _showPayerPickerModal = true;
    }

    private async Task SearchPayerCandidatesAsync()
    {
        if (string.IsNullOrWhiteSpace(_payerSearchTerm))
        {
            _payerSearchResults = new();
            return;
        }
        var result = await PatientService.SearchPatientsAsync(new PatientSearchDto { Query = _payerSearchTerm, PageSize = 10 });
        _payerSearchResults = result.Items.ToList();
    }

    private void SelectPayer(PatientDto candidate)
    {
        _model.PayerPatientId = candidate.Id;
        _model.PayerName = candidate.FullName;
        _showPayerPickerModal = false;
    }

    private void ClearPayer()
    {
        _model.PayerPatientId = null;
        _model.PayerName = null;
    }

    private PatientAddressDto GetOrCreateAddress(PatientAddressType type)
    {
        if (!_addressCache.TryGetValue(type, out var addr))
        {
            addr = new PatientAddressDto { PatientId = Id ?? 0, AddressType = type, AddressSubType = "Not Specified" };
            _addressCache[type] = addr;
        }
        return addr;
    }

    private async Task SaveAddressAsync(PatientAddressDto addr)
    {
        if (!Id.HasValue) return;
        bool ok;
        if (addr.Id == 0)
        {
            var createDto = new CreatePatientAddressDto
            {
                PatientId = Id.Value,
                AddressType = addr.AddressType,
                AddressLine1 = addr.AddressLine1,
                AddressLine2 = addr.AddressLine2,
                Suburb = addr.Suburb,
                Postcode = addr.Postcode,
                State = addr.State,
                AddressSubType = addr.AddressSubType,
                Community = addr.Community,
                SendToMedicare = addr.SendToMedicare
            };
            ok = await AddressService.CreateAsync(createDto);
            if (ok) await LoadAddressesAsync();
        }
        else
        {
            var updateDto = new UpdatePatientAddressDto
            {
                AddressType = addr.AddressType,
                AddressLine1 = addr.AddressLine1,
                AddressLine2 = addr.AddressLine2,
                Suburb = addr.Suburb,
                Postcode = addr.Postcode,
                State = addr.State,
                AddressSubType = addr.AddressSubType,
                Community = addr.Community,
                SendToMedicare = addr.SendToMedicare
            };
            ok = await AddressService.UpdateAsync(Id.Value, addr.Id, updateDto);
        }
        SetStatus(ok ? "Address saved." : "Failed to save address.", !ok);
    }

    private async Task HandleSaveAsync()
    {
        _isSaving = true;
        _statusMessage = null;
        try
        {
            if (Id.HasValue)
            {
                var ok = await PatientService.UpdatePatientAsync(Id.Value, _model);
                SetStatus(ok ? "Saved." : "Failed to save.", !ok);
            }
            else
            {
                var createDto = MapToCreateDto(_model);
                var newId = await PatientService.CreatePatientAsync(createDto);
                if (newId.HasValue)
                {
                    NavManager.NavigateTo($"/patients/edit/{newId.Value}");
                }
                else
                {
                    SetStatus("Failed to create patient.", true);
                }
            }
        }
        finally
        {
            _isSaving = false;
        }
    }

