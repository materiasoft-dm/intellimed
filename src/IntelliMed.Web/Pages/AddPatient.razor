    private void OpenNewClaimModal()
    {
        _claimForm = new CreatePatientCompensationClaimDto { PatientId = Id ?? 0 };
        _editingClaimId = null;
        _showClaimModal = true;
    }

    private void OpenEditClaimModal(PatientCompensationClaimDto c)
    {
        _claimForm = new CreatePatientCompensationClaimDto
        {
            PatientId = c.PatientId,
            ClaimNum = c.ClaimNum,
            DateOfInjury = c.DateOfInjury,
            EmployerName = c.EmployerName,
            CaseManagerName = c.CaseManagerName,
            PayerName = c.PayerName,
            IsDefault = c.IsDefault,
            PublicNote = c.PublicNote,
            PrivateNote = c.PrivateNote
        };
        _editingClaimId = c.Id;
        _showClaimModal = true;
    }

    private async Task SaveClaimAsync()
    {
        if (!Id.HasValue) return;
        bool ok;
        if (_editingClaimId.HasValue)
        {
            var update = new UpdatePatientCompensationClaimDto
            {
                ClaimNum = _claimForm.ClaimNum,
                DateOfInjury = _claimForm.DateOfInjury,
                EmployerName = _claimForm.EmployerName,
                CaseManagerName = _claimForm.CaseManagerName,
                PayerName = _claimForm.PayerName,
                IsDefault = _claimForm.IsDefault,
                PublicNote = _claimForm.PublicNote,
                PrivateNote = _claimForm.PrivateNote,
                IsArchived = false
            };
            ok = await CompensationClaimService.UpdateAsync(Id.Value, _editingClaimId.Value, update);
        }
        else
        {
            ok = await CompensationClaimService.CreateAsync(_claimForm);
        }
        if (ok)
        {
            _showClaimModal = false;
            _claims = (await CompensationClaimService.GetByPatientIdAsync(Id.Value)).ToList();
        }
    }

    private async Task ArchiveClaimAsync(int id)
    {
        if (!Id.HasValue) return;
        await CompensationClaimService.ArchiveAsync(Id.Value, id);
        _claims = (await CompensationClaimService.GetByPatientIdAsync(Id.Value)).ToList();
    }

