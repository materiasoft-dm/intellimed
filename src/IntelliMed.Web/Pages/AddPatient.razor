    private static string HazardSummary(PatientOccupationDto o)
    {
        var hazards = new List<string>();
        if (o.HasAsbestos) hazards.Add("Asbestos");
        if (o.HasDust) hazards.Add("Dust");
        if (o.HasRadiation) hazards.Add("Radiation");
        if (o.HasAnimals) hazards.Add("Animals");
        return string.Join(", ", hazards);
    }

