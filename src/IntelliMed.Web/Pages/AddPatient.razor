        @if (_showUdfModal)
        {
            <div class="modal d-block" tabindex="-1" style="background: rgba(0,0,0,0.4);">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content">
                        <div class="modal-header py-2">
                            <h6 class="modal-title">@(_editingUdfValueId.HasValue ? "Edit Field Value" : "New Field Value")</h6>
                            <button type="button" class="btn-close" @onclick="@(() => _showUdfModal = false)"></button>
                        </div>
                        <div class="modal-body">
                            <div class="row g-2">
                                <div class="col-12">
                                    <label class="form-label small mb-0">Field Name</label>
                                    <select class="form-select form-select-sm" @bind="_udfFieldTypeId" disabled="@_editingUdfValueId.HasValue">
                                        @foreach (var d in _udfDefinitions)
                                        {
                                            <option value="@d.Id">@d.Name</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-12">
                                    <label class="form-label small mb-0">Value</label>
                                    <input class="form-control form-control-sm" @bind="_udfValueText" />
                                </div>
                                <div class="col-12">
                                    <label class="form-label small mb-0">Note</label>
                                    <textarea class="form-control form-control-sm" rows="2" @bind="_udfNoteText"></textarea>
                                </div>
                            </div>
                        </div>
                        <div class="modal-footer py-2">
                            <button type="button" class="btn btn-sm btn-secondary" @onclick="@(() => _showUdfModal = false)">Cancel</button>
                            <button type="button" class="btn btn-sm btn-primary" @onclick="SaveUdfValueAsync">Save</button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>;
}
