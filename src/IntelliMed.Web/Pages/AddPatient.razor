    private void OpenNewUdfModal()
    {
        _udfFieldTypeId = _udfDefinitions.FirstOrDefault()?.Id;
        _udfValueText = null;
        _udfNoteText = null;
        _editingUdfValueId = null;
        _showUdfModal = true;
