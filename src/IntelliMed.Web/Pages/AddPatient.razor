    private void OpenEditUdfModal(PatientUserDefinedFieldValueDto v)
    {
        _udfFieldTypeId = v.UserDefinedFieldTypeId;
        _udfValueText = v.Value;
        _udfNoteText = v.Note;
        _editingUdfValueId = v.Id;
        _showUdfModal = true;
    }

    private async Task SaveUdfValueAsync()
    {
        if (!Id.HasValue || !_udfFieldTypeId.HasValue) return;
        bool ok;
        if (_editingUdfValueId.HasValue)
        {
            var update = new UpdatePatientUserDefinedFieldValueDto { Value = _udfValueText, Note = _udfNoteText };
            ok = await UdfValueService.UpdateAsync(Id.Value, _editingUdfValueId.Value, update);
        }
        else
        {
            var create = new CreatePatientUserDefinedFieldValueDto
            {
                PatientId = Id.Value,
                UserDefinedFieldTypeId = _udfFieldTypeId.Value,
                Value = _udfValueText,
                Note = _udfNoteText
            };
            ok = await UdfValueService.CreateAsync(create);
        }
        if (ok)
        {
            _showUdfModal = false;
            _udfValues = (await UdfValueService.GetByPatientIdAsync(Id.Value)).ToList();
        }
    }

    private async Task DeleteUdfValueAsync(int id)
    {
        if (!Id.HasValue) return;
        await UdfValueService.DeleteAsync(Id.Value, id);
        _udfValues = (await UdfValueService.GetByPatientIdAsync(Id.Value)).ToList();
    }

