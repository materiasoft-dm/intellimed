    // ===================== Referrals =====================
    private void OpenNewReferralModal()
    {
        _referralForm = new CreatePatientReferralDto { PatientId = Id ?? 0, ReferralDate = DateTime.Today };
        _editingReferralId = null;
        _showReferralModal = true;
    }

    private void OpenEditReferralModal(PatientReferralDto r)
    {
        _referralForm = new CreatePatientReferralDto
        {
            PatientId = r.PatientId,
            ReferralDate = r.ReferralDate,
            ReferralPeriod = r.ReferralPeriod,
            IsDefault = r.IsDefault,
            IsGP = r.IsGP,
            ReferringProviderName = r.ReferringProviderName,
            ReferringProviderNumber = r.ReferringProviderNumber,
            RequestTypeCde = r.RequestTypeCde,
            FirstVisitDate = r.FirstVisitDate,
            Note = r.Note
        };
        _editingReferralId = r.Id;
        _showReferralModal = true;
    }

    private async Task SaveReferralAsync()
    {
        if (!Id.HasValue) return;
        bool ok;
        if (_editingReferralId.HasValue)
        {
            var update = new UpdatePatientReferralDto
            {
                ReferralDate = _referralForm.ReferralDate,
                ReferralPeriod = _referralForm.ReferralPeriod,
                IsDefault = _referralForm.IsDefault,
                IsGP = _referralForm.IsGP,
                ReferringProviderName = _referralForm.ReferringProviderName,
                ReferringProviderNumber = _referralForm.ReferringProviderNumber,
                RequestTypeCde = _referralForm.RequestTypeCde,
                FirstVisitDate = _referralForm.FirstVisitDate,
                Note = _referralForm.Note,
                IsArchived = false
            };
            ok = await ReferralService.UpdateAsync(Id.Value, _editingReferralId.Value, update);
        }
        else
        {
            ok = await ReferralService.CreateAsync(_referralForm);
        }
        if (ok)
        {
            _showReferralModal = false;
            _referrals = (await ReferralService.GetByPatientIdAsync(Id.Value)).ToList();
        }
    }

    private async Task ArchiveReferralAsync(int id)
    {
        if (!Id.HasValue) return;
        await ReferralService.ArchiveAsync(Id.Value, id);
        _referrals = (await ReferralService.GetByPatientIdAsync(Id.Value)).ToList();
    }

    private async Task DeleteReferralAsync(int id)
    {
        if (!Id.HasValue) return;
        await ReferralService.DeleteAsync(Id.Value, id);
        _referrals = (await ReferralService.GetByPatientIdAsync(Id.Value)).ToList();
    }

    private RenderFragment RenderReferralsTab() => @<div>
        <div class="d-flex justify-content-between mb-1">
            <div class="form-check">
                <input type="checkbox" class="form-check-input" id="chkInclArchivedRef" @bind="_includeArchivedReferrals" />
