@page "/login"
@layout PublicLayout

@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Components.Forms
@using MudBlazor
@using IntelliMed.Web.Services
@inject IAuthService AuthService
@inject NavigationManager Navigation

<MudLayout>
    <MudContainer MaxWidth="MaxWidth.False" Class="login-container pa-0">
        <div class="login-split">
            <!-- Left side - Clinic Image -->
            <div class="login-image-section">
                <div class="login-image-overlay"></div>
                <img src="https://images.unsplash.com/photo-1519494026892-80bbd2d6fd0d?w=1200&q=80" 
                     alt="Modern medical clinic" 
                     class="login-image" />
                <div class="login-brand-overlay">
                    <MudIcon Icon="@Icons.Material.Filled.LocalHospital" Size="Size.Large" Class="brand-icon" />
                    <h1 class="brand-title">IntelliMed</h1>
                    <p class="brand-subtitle">Practice Management System</p>
                </div>
                <div class="login-quote">
                    <p>"Streamline your practice with intelligent, integrated healthcare management."</p>
                </div>
            </div>

            <!-- Right side - Login Form -->
            <div class="login-form-section">
                <div class="login-form-wrapper">
                    <div class="login-form-header">
                        <MudText Typo="Typo.h4" Class="welcome-text">Welcome Back</MudText>
                        <MudText Typo="Typo.body1" Class="subtitle-text">
                            Sign in to access your practice dashboard
                        </MudText>
                    </div>

                    <MudForm @ref="_form" @bind-IsValid="@_isValid" Class="login-form">
                        <MudTextField @bind-Value="_model.Email"
                                      Label="Email Address"
                                      Placeholder="name@clinic.com"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Normal"
                                      Required="true"
                                      RequiredError="Email is required"
                                      Class="login-field"
                                      Immediate="true" />

                        <MudTextField @bind-Value="_model.Password"
                                      Label="Password"
                                      Placeholder="Enter your password"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Normal"
                                      Required="true"
                                      RequiredError="Password is required"
                                      InputType="@(_showPassword ? InputType.Text : InputType.Password)"
                                      Class="login-field"
                                      Immediate="true" />

                        <div class="form-options">
                            <MudCheckBox @bind-Checked="_model.RememberMe" 
                                         Label="Remember me" 
                                         Color="Color.Primary"
                                         Dense="true" />
                            <MudLink Href="/forgot-password" 
                                     Class="forgot-link"
                                     Underline="Underline.Hover">
                                Forgot password?
                            </MudLink>
                        </div>

                        <MudButton Variant="Variant.Filled" 
                                   Color="Color.Primary"
                                   Size="Size.Large"
                                   FullWidth="true"
                                   Class="login-button"
                                   Disabled="@_isLoading"
                                   OnClick="HandleLogin">
                            @if (_isLoading)
                            {
                                <MudProgressCircular Class="mr-2" Size="Size.Small" Indeterminate="true" />
                                <span>Signing in...</span>
                            }
                            else
                            {
                                <span>Sign In</span>
                            }
                        </MudButton>

                        @if (!string.IsNullOrEmpty(_loginError))
                        {
                            <MudAlert Severity="Severity.Error" Class="mt-3" Dense="true">
                                @_loginError
                            </MudAlert>
                        }
                    </MudForm>

                    <MudDivider Class="my-6" />

                    <div class="login-footer">
                        <MudText Typo="Typo.body2" Class="footer-text">
                            Protected by enterprise-grade security
                        </MudText>
                        <div class="security-badges">
                            <MudChip Icon="@Icons.Material.Filled.Lock" 
                                     Size="Size.Small" 
                                     Variant="Variant.Outlined"
                                     Class="security-chip">
                                HIPAA Compliant
                            </MudChip>
                            <MudChip Icon="@Icons.Material.Filled.VerifiedUser" 
                                     Size="Size.Small" 
                                     Variant="Variant.Outlined"
                                     Class="security-chip">
                                256-bit SSL
                            </MudChip>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </MudContainer>
</MudLayout>

<style>
    .login-container {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        height: 100vh;
        width: 100vw;
        max-width: 100vw !important;
        padding: 0 !important;
        margin: 0 !important;
        overflow: hidden;
    }

    html, body {
        overflow: hidden;
        height: 100%;
        width: 100%;
        margin: 0;
        padding: 0;
    }

    /* Ensure MudLayout doesn't add extra space */
    .mud-layout {
        height: 100%;
        overflow: hidden;
    }

    .login-split {
        display: flex;
        height: 100%;
    }

    /* Left Image Section */
    .login-image-section {
        flex: 1;
        position: relative;
        display: none;
        overflow: hidden;
    }

    @@media (min-width: 960px) {
        .login-image-section {
            display: block;
        }
    }

    .login-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        position: absolute;
        top: 0;
        left: 0;
    }

    .login-image-overlay {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: linear-gradient(
            135deg,
            rgba(25, 118, 210, 0.85) 0%,
            rgba(0, 77, 64, 0.75) 50%,
            rgba(13, 71, 161, 0.9) 100%
        );
        z-index: 1;
    }

    .login-brand-overlay {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -60%);
        text-align: center;
        z-index: 2;
        color: white;
    }

    .brand-icon {
        font-size: 4rem !important;
        width: 4rem !important;
        height: 4rem !important;
        margin-bottom: 1rem;
        filter: drop-shadow(0 4px 8px rgba(0,0,0,0.3));
    }

    .brand-title {
        font-size: 3rem;
        font-weight: 700;
        margin: 0;
        letter-spacing: 2px;
        text-shadow: 0 4px 12px rgba(0,0,0,0.3);
    }

    .brand-subtitle {
        font-size: 1.1rem;
        margin-top: 0.5rem;
        opacity: 0.9;
        letter-spacing: 1px;
    }

    .login-quote {
        position: absolute;
        bottom: 60px;
        left: 50%;
        transform: translateX(-50%);
        z-index: 2;
        text-align: center;
        color: white;
        max-width: 400px;
        padding: 0 2rem;
    }

    .login-quote p {
        font-size: 1rem;
        font-style: italic;
        opacity: 0.95;
        line-height: 1.6;
        text-shadow: 0 2px 8px rgba(0,0,0,0.3);
    }

    /* Right Form Section */
    .login-form-section {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(180deg, #f8fafc 0%, #ffffff 100%);
        padding: 2rem;
    }

    .login-form-wrapper {
        width: 100%;
        max-width: 400px;
    }

    .login-form-header {
        margin-bottom: 2rem;
        text-align: center;
    }

    .welcome-text {
        font-weight: 700;
        color: #1a1a2e;
        margin-bottom: 0.5rem;
    }

    .subtitle-text {
        color: #64748b;
    }

    .login-form {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .login-field {
        margin-bottom: 0;
    }

    /* Fix MudBlazor label positioning for outlined variant */
    .login-field.mud-input-control {
        margin-top: 0 !important;
        padding-top: 0 !important;
    }

    .login-field .mud-input-label {
        position: absolute !important;
        top: -8px !important;
        left: 12px !important;
        transform: none !important;
        background: white !important;
        padding: 0 4px !important;
        font-size: 0.75rem !important;
    }

    .login-field .mud-input-label.mud-input-label-inputcontrol {
        top: -8px !important;
        transform: none !important;
    }

    .login-field .mud-input-control-input-control {
        margin-top: 0 !important;
    }

    .login-field .mud-input {
        padding-top: 16px !important;
    }

    .login-field .mud-input-slot {
        padding-top: 8px !important;
    }

    .form-options {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin: 0.5rem 0 1.5rem;
    }

    .forgot-link {
        font-size: 0.875rem;
        color: #1976d2;
    }

    .login-button {
        height: 52px;
        font-size: 1rem;
        font-weight: 600;
        letter-spacing: 0.5px;
        text-transform: uppercase;
        margin-top: 0.5rem;
        box-shadow: 0 4px 14px rgba(25, 118, 210, 0.4);
        transition: all 0.3s ease;
    }

    .login-button:hover {
        box-shadow: 0 6px 20px rgba(25, 118, 210, 0.5);
        transform: translateY(-1px);
    }

    .login-footer {
        text-align: center;
    }

    .footer-text {
        color: #94a3b8;
        margin-bottom: 1rem;
    }

    .security-badges {
        display: flex;
        justify-content: center;
        gap: 0.75rem;
        flex-wrap: wrap;
    }

    .security-chip {
        font-size: 0.75rem;
        color: #64748b;
        border-color: #e2e8f0;
    }

    /* Responsive adjustments */
    @@media (max-width: 600px) {
        .login-form-section {
            padding: 1.5rem;
        }

        .login-form-wrapper {
            max-width: 100%;
        }

        .brand-title {
            font-size: 2rem;
        }

        .form-options {
            flex-direction: column;
            gap: 0.75rem;
            align-items: flex-start;
        }
    }
</style>

@code {
    private MudForm? _form;
    private bool _isValid;
    private bool _isLoading;
    private bool _showPassword;
    private string? _loginError;

    private LoginModel _model = new();

    protected override async Task OnInitializedAsync()
    {
        // Check if already logged in, redirect to home
        if (await AuthService.IsAuthenticatedAsync())
        {
            Navigation.NavigateTo("/");
        }

#if DEBUG
        // Pre-fill credentials for debugging convenience
        _model.Email = "admin@clinic.com";
        _model.Password = "IntelliMed2024!";
#endif
    }

    private void TogglePasswordVisibility()
    {
        _showPassword = !_showPassword;
    }

    private async Task HandleLogin()
    {
        if (_form != null)
        {
            await _form.Validate();

            if (_isValid)
            {
                _isLoading = true;
                _loginError = null;
                StateHasChanged();

                try
                {
                    var response = await AuthService.LoginAsync(_model.Email, _model.Password);

                    if (response?.Success == true)
                    {
                        Navigation.NavigateTo("/");
                    }
                    else
                    {
                        _loginError = response?.ErrorMessage ?? "Invalid email or password. Please try again.";
                    }
                }
                catch (Exception ex)
                {
                    _loginError = "An error occurred. Please try again.";
                    Console.Error.WriteLine($"Login error: {ex.Message}");
                }
                finally
                {
                    _isLoading = false;
                    StateHasChanged();
                }
            }
        }
    }

    private class LoginModel
    {
        [Required]
        [EmailAddress]
        public string Email { get; set; } = string.Empty;

        [Required]
        public string Password { get; set; } = string.Empty;

        public bool RememberMe { get; set; }
    }
}