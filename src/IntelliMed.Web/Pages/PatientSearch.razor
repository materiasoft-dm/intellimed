@page "/patients/search"
@layout MainLayout
@using System.Text
@using IntelliMed.Core.DTOs
@using IntelliMed.Core.Entities
@using IntelliMed.Web.Services
@inject IPatientService PatientService
@inject IHealthFundService HealthFundService
@inject NavigationManager Navigation

<PageTitle>Patient Search - IntelliMed</PageTitle>

<h4 class="mb-4">Patient Search</h4>

@* Error state (the grid shows its own loading spinner) *@
@if (!string.IsNullOrEmpty(_error))
{
    <div class="alert alert-danger d-flex align-items-center mb-4">
        <i class="bi bi-exclamation-triangle me-2"></i> @_error
        <button class="btn btn-outline-danger btn-sm ms-auto" @onclick="RefreshAsync">Retry</button>
    </div>
}

@* Layout: left filter sidebar and main results area *@
<div class="row">
    @* Left-Hand Sidebar *@
    <div class="col-12 col-md-3">
        <div class="card mb-4 filter-panel-card">
            <div class="card-header d-flex align-items-center justify-content-between">
                <ul class="nav nav-tabs card-header-tabs flex-grow-1 mb-0">
                    <li class="nav-item"><a class="nav-link @(_activeTab == "Basic" ? "active" : "")" href="#" @onclick="@(() => _activeTab = "Basic")" @onclick:preventDefault>Basic</a></li>
                    <li class="nav-item"><a class="nav-link @(_activeTab == "Advance" ? "active" : "")" href="#" @onclick="@(() => _activeTab = "Advance")" @onclick:preventDefault>Advance</a></li>
                </ul>
                <button type="button" class="btn btn-sm btn-link text-decoration-none d-md-none p-0 ms-2"
                        @onclick="@(() => _mobileFiltersExpanded = !_mobileFiltersExpanded)" title="Show/hide filters">
                    <i class="bi @(_mobileFiltersExpanded ? "bi-chevron-up" : "bi-chevron-down")"></i>
                </button>
            </div>
            <div class="card-body filter-panel-body @(_mobileFiltersExpanded ? "" : "d-none d-md-block")" @onkeydown="HandleFilterKeyDown">
                @if (_activeTab == "Basic")
                {
                    <div class="filter-section-header d-flex justify-content-between align-items-center" @onclick="@(() => _secIdentifiers = !_secIdentifiers)">
                        <span class="small fw-semibold text-uppercase text-muted">Identifiers</span>
                        <i class="bi @(_secIdentifiers ? "bi-chevron-up" : "bi-chevron-down") small text-muted"></i>
                    </div>
                    @if (_secIdentifiers)
                    {
                        <div class="row g-2 mb-1">
                            <div class="col-6 d-flex align-items-center gap-1 flex-wrap">
                                <label class="form-label small filter-label-sm">Family/Org</label>
                                <input class="form-control form-control-sm" @bind="_filter.Surname" @bind:event="oninput" />
                            </div>
                            <div class="col-6 d-flex align-items-center gap-1 flex-wrap">
                                <label class="form-label small filter-label-sm">First</label>
                                <input class="form-control form-control-sm" @bind="_filter.GivenName" @bind:event="oninput" />
                            </div>
                        </div>
                        <div class="row g-2 mb-1">
                            <div class="col-6 d-flex align-items-center gap-1 flex-wrap">
                                <label class="form-label small filter-label-sm">Medicare#</label>
                                <input class="form-control form-control-sm" @bind="_filter.MedicareNumber" @bind:event="oninput" />
                            </div>
                            <div class="col-6 d-flex align-items-center gap-1 flex-wrap">
                                <label class="form-label small filter-label-sm">Gender</label>
                                <select class="form-select form-select-sm" @bind="_filter.Gender">
                                    <option value="">All</option>
                                    <option value="@GenderEnum.Unspecified">Unspecified</option>
                                    <option value="@GenderEnum.Male">Male</option>
                                    <option value="@GenderEnum.Female">Female</option>
                                    <option value="@GenderEnum.Other">Other</option>
                                </select>
                            </div>
                        </div>
                        <div class="row g-2 mb-1">
                            <div class="col-6 d-flex align-items-center gap-1 flex-wrap">
                                <label class="form-label small filter-label-sm">DVA#</label>
                                <input class="form-control form-control-sm" @bind="_filter.DvaNumber" @bind:event="oninput" />
                            </div>
                            <div class="col-6 d-flex align-items-center gap-1 flex-wrap">
                                <label class="form-label small filter-label-sm">File#</label>
                                <input class="form-control form-control-sm" @bind="_filter.FileNumber" @bind:event="oninput" />
                            </div>
                        </div>
                        <div class="row g-2 mb-1">
                            <div class="col-6 d-flex align-items-center gap-1 flex-wrap">
                                <label class="form-label small filter-label-sm">Pension</label>
                                <input class="form-control form-control-sm" @bind="_filter.PensionNumber" @bind:event="oninput" />
                            </div>
                            <div class="col-6 d-flex align-items-center gap-1 flex-wrap">
                                <label class="form-label small filter-label-sm">Fund#</label>
                                <input class="form-control form-control-sm" @bind="_filter.HealthFundNumber" @bind:event="oninput" />
                            </div>
                        </div>
                        <div class="d-flex align-items-center gap-2 mb-1 flex-wrap">
                            <label class="form-label small filter-label">Lifecard#</label>
                            <input class="form-control form-control-sm" @bind="_filter.LifeCardNum" @bind:event="oninput" />
                        </div>

                        <div class="d-flex align-items-center gap-2 mb-1 flex-wrap">
                            <label class="form-label small filter-label">D.O.B.</label>
                            <input type="date" class="form-control form-control-sm" @bind="_filter.DobFrom" />
                            <span class="small text-muted">-</span>
                            <input type="date" class="form-control form-control-sm" @bind="_filter.DobTo" />
                        </div>
                    }

                    <hr class="my-2" />

                    <div class="filter-section-header d-flex justify-content-between align-items-center" @onclick="@(() => _secAddress = !_secAddress)">
                        <span class="small fw-semibold text-uppercase text-muted">Address</span>
                        <i class="bi @(_secAddress ? "bi-chevron-up" : "bi-chevron-down") small text-muted"></i>
                    </div>
                    @if (_secAddress)
                    {
                        <div class="d-flex align-items-center gap-2 mb-1 flex-wrap">
                            <label class="form-label small filter-label">Address</label>
                            <input class="form-control form-control-sm" @bind="_filter.Address" @bind:event="oninput" />
                        </div>
                        <div class="d-flex align-items-center gap-2 mb-1 flex-wrap">
                            <span class="filter-label"></span>
                            <input class="form-control form-control-sm" placeholder="Suburb" @bind="_filter.Suburb" @bind:event="oninput" />
                            <input class="form-control form-control-sm" placeholder="Postcode" @bind="_filter.Postcode" @bind:event="oninput" />
                            <input class="form-control form-control-sm" placeholder="State" @bind="_filter.State" @bind:event="oninput" />
                        </div>

                        <div class="d-flex align-items-center gap-2 mb-1 flex-wrap">
                            <label class="form-label small filter-label">Postal Addr</label>
                            <input class="form-control form-control-sm" @bind="_filter.PostalAddress" @bind:event="oninput" />
                        </div>
                        <div class="d-flex align-items-center gap-2 mb-1 flex-wrap">
                            <span class="filter-label"></span>
                            <input class="form-control form-control-sm" placeholder="Suburb" @bind="_filter.PostalSuburb" @bind:event="oninput" />
                            <input class="form-control form-control-sm" placeholder="Postcode" @bind="_filter.PostalPostcode" @bind:event="oninput" />
                            <input class="form-control form-control-sm" placeholder="State" @bind="_filter.PostalState" @bind:event="oninput" />
                        </div>
                    }

                    <hr class="my-2" />

                    <div class="filter-section-header d-flex justify-content-between align-items-center" @onclick="@(() => _secContact = !_secContact)">
                        <span class="small fw-semibold text-uppercase text-muted">Contact</span>
                        <i class="bi @(_secContact ? "bi-chevron-up" : "bi-chevron-down") small text-muted"></i>
                    </div>
                    @if (_secContact)
                    {
                        <div class="row g-2 mb-1">
                            <div class="col-6 d-flex align-items-center gap-1 flex-wrap">
                                <label class="form-label small filter-label-sm">Home Ph.</label>
                                <input class="form-control form-control-sm" @bind="_filter.HomePhone" @bind:event="oninput" />
                            </div>
                            <div class="col-6 d-flex align-items-center gap-1 flex-wrap">
                                <label class="form-label small filter-label-sm">B.H.</label>
                                <input class="form-control form-control-sm" @bind="_filter.BusinessHoursPhone" @bind:event="oninput" />
                            </div>
                        </div>
                        <div class="d-flex align-items-center gap-2 mb-1 flex-wrap">
                            <label class="form-label small filter-label">Mobile Phone</label>
                            <input class="form-control form-control-sm" @bind="_filter.MobilePhone" @bind:event="oninput" />
                        </div>
                        <div class="d-flex align-items-center gap-2 mb-1 flex-wrap">
                            <label class="form-label small filter-label">Email</label>
                            <input class="form-control form-control-sm" @bind="_filter.Email" @bind:event="oninput" />
                        </div>

                        <div class="d-flex align-items-center gap-2 mb-1 flex-wrap">
                            <label class="form-label small filter-label">ATSI</label>
                            <select class="form-select form-select-sm" @bind="_filter.AtsiStatus">
                                <option value="">All</option>
                                <option value="@AtsiStatusEnum.NotAsked">Not Asked</option>
                                <option value="@AtsiStatusEnum.AboriginalOnly">Aboriginal Only</option>
                                <option value="@AtsiStatusEnum.TorresStraitIslanderOnly">TSI Only</option>
                                <option value="@AtsiStatusEnum.Both">Both</option>
                                <option value="@AtsiStatusEnum.NeitherAboriginalNorTorresStraitIslander">Neither</option>
                            </select>
                        </div>
                    }

                    <hr class="my-2" />

                    <div class="filter-section-header d-flex justify-content-between align-items-center" @onclick="@(() => _secDates = !_secDates)">
                        <span class="small fw-semibold text-uppercase text-muted">Date Ranges</span>
                        <i class="bi @(_secDates ? "bi-chevron-up" : "bi-chevron-down") small text-muted"></i>
                    </div>
                    @if (_secDates)
                    {
                        <div class="d-flex align-items-center gap-2 mb-1 flex-wrap">
                            <label class="form-label small filter-label">Created</label>
                            <input type="date" class="form-control form-control-sm" @bind="_filter.CreatedFrom" />
                            <span class="small text-muted">-</span>
                            <input type="date" class="form-control form-control-sm" @bind="_filter.CreatedTo" />
                        </div>
                        <div class="d-flex align-items-center gap-2 mb-1 flex-wrap">
                            <label class="form-label small filter-label">Medicare EXP</label>
                            <input type="date" class="form-control form-control-sm" @bind="_filter.MedicareExpiryFrom" />
                            <span class="small text-muted">-</span>
                            <input type="date" class="form-control form-control-sm" @bind="_filter.MedicareExpiryTo" />
                        </div>
                        <div class="d-flex align-items-center gap-2 mb-1 flex-wrap">
                            <label class="form-label small filter-label">PHI Joined</label>
                            <input type="date" class="form-control form-control-sm" @bind="_filter.HealthFundJoinFrom" />
                            <span class="small text-muted">-</span>
                            <input type="date" class="form-control form-control-sm" @bind="_filter.HealthFundJoinTo" />
                        </div>
                    }

                    <hr class="my-2" />

                    <div class="filter-section-header d-flex justify-content-between align-items-center" @onclick="@(() => _secAccount = !_secAccount)">
                        <span class="small fw-semibold text-uppercase text-muted">Account / Notes</span>
                        <i class="bi @(_secAccount ? "bi-chevron-up" : "bi-chevron-down") small text-muted"></i>
                    </div>
                    @if (_secAccount)
                    {
                        <div class="d-flex align-items-center gap-2 mb-1 flex-wrap">
                            <label class="form-label small filter-label">Warnings</label>
                            <input class="form-control form-control-sm" @bind="_filter.Warnings" @bind:event="oninput" />
                        </div>
                        <div class="d-flex align-items-center gap-2 mb-1 flex-wrap">
                            <label class="form-label small filter-label">Note</label>
                            <input class="form-control form-control-sm" @bind="_filter.Notes" @bind:event="oninput" />
                        </div>
                        <div class="d-flex align-items-center gap-2 mb-1 flex-wrap">
                            <label class="form-label small filter-label">Referred by</label>
                            <div class="input-group input-group-sm">
                                <input class="form-control form-control-sm" @bind="_filter.ReferredBy" @bind:event="oninput" />
                                @if (!string.IsNullOrEmpty(_filter.ReferredBy))
                                {
                                    <button type="button" class="btn btn-outline-secondary" @onclick="@(() => _filter.ReferredBy = null)">x</button>
                                }
                            </div>
                        </div>
                        <div class="d-flex align-items-center gap-2 mb-1 flex-wrap">
                            <label class="form-label small filter-label">Patient Type</label>
                            <select class="form-select form-select-sm" @bind="_filter.PatientType">
                                <option value="">All</option>
                                <option value="@PatientTypeEnum.Person">Person</option>
                                <option value="@PatientTypeEnum.Organisation">Organisation</option>
                            </select>
                        </div>
                        <div class="d-flex align-items-center gap-2 mb-1 flex-wrap">
                            <label class="form-label small filter-label">UR No</label>
                            <input class="form-control form-control-sm" @bind="_filter.UrNumber" @bind:event="oninput" />
                        </div>
                        <div class="d-flex align-items-center gap-2 mb-1 flex-wrap">
                            <label class="form-label small filter-label">Fund Id</label>
                            <select class="form-select form-select-sm" @bind="_filter.HealthFundId">
                                <option value="">All</option>
                                @foreach (var fund in _healthFunds)
                                {
                                    <option value="@fund.Id">@fund.Code - @fund.Name</option>
                                }
                            </select>
                        </div>
                        <div class="d-flex align-items-center gap-2 mb-1 flex-wrap">
                            <label class="form-label small filter-label">DF Payer</label>
                            <div class="input-group input-group-sm">
                                <input class="form-control form-control-sm" value="@_payerDisplayName" readonly placeholder="Any" />
                                <button type="button" class="btn btn-outline-secondary" @onclick="OpenPayerPicker">Find</button>
                                @if (_filter.PayerPatientId.HasValue)
                                {
                                    <button type="button" class="btn btn-outline-secondary" @onclick="ClearPayer">x</button>
                                }
                            </div>
                        </div>

                        <div class="d-flex align-items-start gap-2 mb-1">
                            <label class="form-label small filter-label mt-1">DF Acc. Type</label>
                            <div class="border rounded p-2 flex-grow-1" style="max-height: 140px; overflow-y: auto;">
                                @foreach (var type in Enum.GetValues<AccountTypeEnum>())
                                {
                                    <div class="form-check form-check-sm">
                                        <input class="form-check-input" type="checkbox" id="acctype_@type"
                                               checked="@_selectedAccountTypes.Contains(type)"
                                               @onchange="@(e => ToggleAccountType(type, (bool)e.Value!))" />
                                        <label class="form-check-label small" for="acctype_@type">@type</label>
                                    </div>
                                }
                            </div>
                        </div>
                    }

                    <hr class="my-2" />

                    <div class="filter-section-header d-flex justify-content-between align-items-center" @onclick="@(() => _secFlags = !_secFlags)">
                        <span class="small fw-semibold text-uppercase text-muted">Flags</span>
                        <i class="bi @(_secFlags ? "bi-chevron-up" : "bi-chevron-down") small text-muted"></i>
                    </div>
                    @if (_secFlags)
                    {
                        <div class="row g-2 mb-2">
                            <div class="col-6">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="chkDeceased" @bind="_filter.Deceased" />
                                    <label class="form-check-label small" for="chkDeceased">Deceased</label>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="chkArchived" @bind="_filter.IncludeArchived" />
                                    <label class="form-check-label small" for="chkArchived">Archived</label>
                                </div>
                            </div>
                        </div>
                        <div class="d-flex align-items-center gap-2 mb-1 flex-wrap">
                            <label class="form-label small filter-label">Accept Email</label>
                            <select class="form-select form-select-sm" @bind="_filter.AcceptEmail">
                                <option value="">Any</option>
                                <option value="true">Yes</option>
                                <option value="false">No</option>
                            </select>
                        </div>
                        <div class="d-flex align-items-center gap-2 mb-1 flex-wrap">
                            <label class="form-label small filter-label">Accept SMS</label>
                            <select class="form-select form-select-sm" @bind="_filter.AcceptSms">
                                <option value="">Any</option>
                                <option value="true">Yes</option>
                                <option value="false">No</option>
                            </select>
                        </div>
                        <div class="d-flex align-items-center gap-2 mb-3 flex-wrap">
                            <label class="form-label small filter-label">SMS Mktg</label>
                            <select class="form-select form-select-sm" @bind="_filter.AcceptSmsMarketing">
                                <option value="">Any</option>
                                <option value="true">Yes</option>
                                <option value="false">No</option>
                            </select>
                        </div>
                    }
                }
                else
                {
                    <div class="text-muted small">Advanced filters coming soon.</div>
                }
            </div>
            <div class="card-footer d-flex justify-content-between filter-panel-footer @(_mobileFiltersExpanded ? "" : "d-none d-md-flex")">
                <button type="button" class="btn btn-primary" @onclick="FindAsync">Find</button>
                <button type="button" class="btn btn-secondary" @onclick="ClearFilters">Clear</button>
            </div>
        </div>
    </div>
    @* Main Patient Data Grid *@
    <div class="col-12 col-md-9 mt-3 mt-md-0">
        <div class="card">
            <div class="card-header d-flex align-items-center justify-content-between py-2">
                <span class="small text-muted"><i class="bi bi-heart-pulse me-1"></i> Total Patients: <strong>@_totalCount</strong></span>
                <button class="btn btn-sm btn-outline-primary" @onclick="RefreshAsync">
                    <i class="bi bi-arrow-clockwise me-1"></i> Refresh
                </button>
            </div>

            @* Desktop/tablet: full data grid with column show/hide/reorder + server paging *@
            <div class="d-none d-md-block">
                <RadzenDataGrid @ref="_grid" TItem="PatientDto" Data="@_patients" Count="@_totalCount"
                                 LoadData="@LoadDataAsync" IsLoading="@_isLoading"
                                 AllowPaging="true" PageSize="@_pageSize" PagerHorizontalAlign="HorizontalAlign.Center"
                                 AllowColumnResize="true" AllowColumnReorder="true" AllowColumnPicking="true"
                                 SelectionMode="DataGridSelectionMode.Single"
                                 RowSelect="@(p => SelectPatient(p))"
                                 EmptyText="No patients found.">
                    <Columns>
                        <RadzenDataGridColumn TItem="PatientDto" Property="FullName" Title="Patient Name" Width="180px">
                            <Template Context="p">
                                <a href="javascript:void(0)" class="link-primary" @onclick="() => EditPatient(p)" @onclick:stopPropagation>@p.FullName</a>
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="PatientDto" Property="FirstName" Title="Preferred" Width="120px" />
                        <RadzenDataGridColumn TItem="PatientDto" Property="DateOfBirth" Title="D.O.B." Width="110px" FormatString="{0:dd/MM/yyyy}" />
                        <RadzenDataGridColumn TItem="PatientDto" Title="File#" Width="80px">
                            <Template Context="p">@p.Id.ToString("D5")</Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="PatientDto" Property="FullAddress" Title="Street Address" Width="220px" />
                        <RadzenDataGridColumn TItem="PatientDto" Property="Phone" Title="Home Phone" Width="120px" />
                        <RadzenDataGridColumn TItem="PatientDto" Property="BusinessHoursPhone" Title="B.H. Phone" Width="120px" />
                        <RadzenDataGridColumn TItem="PatientDto" Property="MobilePhone" Title="Mobile Phone" Width="120px" />
                        <RadzenDataGridColumn TItem="PatientDto" Property="Gender" Title="Gender" Width="100px" />
                        <RadzenDataGridColumn TItem="PatientDto" Property="AccountType" Title="DF Acc. Type" Width="130px" />
                        <RadzenDataGridColumn TItem="PatientDto" Property="MedicareNumber" Title="Medicare#" Width="130px" />
                        <RadzenDataGridColumn TItem="PatientDto" Property="DvaNumber" Title="Veteran#" Width="110px" />
                        <RadzenDataGridColumn TItem="PatientDto" Property="HealthFundCode" Title="Fund ID" Width="90px" />
                        <RadzenDataGridColumn TItem="PatientDto" Property="Email" Title="Email" Width="180px" />
                    </Columns>
                </RadzenDataGrid>
            </div>

            @* Mobile only: card list — the grid above stays mounted (hidden) so it keeps driving paging/loading *@
            <div class="d-md-none p-2">
                @if (_isLoading)
                {
                    <div class="text-center text-muted py-4">
                        <span class="spinner-border spinner-border-sm text-primary me-2"></span> Loading...
                    </div>
                }
                else if (_patients.Count == 0)
                {
                    <div class="text-center text-muted py-4">No patients found.</div>
                }
                else
                {
                    @foreach (var p in _patients)
                    {
                        <div class="card mb-2 patient-mobile-card @(p == _selectedPatient ? "border-primary" : "")" @onclick="() => SelectPatient(p)">
                            <div class="card-body py-2 px-3">
                                <div class="d-flex justify-content-between align-items-start">
                                    <a href="javascript:void(0)" class="fw-semibold link-primary" @onclick="() => EditPatient(p)" @onclick:stopPropagation>@p.FullName</a>
                                    @if (p == _selectedPatient)
                                    {
                                        <i class="bi bi-check-circle-fill text-primary"></i>
                                    }
                                </div>
                                <div class="small text-muted">File# @p.Id.ToString("D5") &middot; @p.DateOfBirth.ToString("dd/MM/yyyy")</div>
                                @if (!string.IsNullOrWhiteSpace(p.FullAddress))
                                {
                                    <div class="small mt-1"><i class="bi bi-geo-alt text-muted me-1"></i>@p.FullAddress</div>
                                }
                                @if (!string.IsNullOrWhiteSpace(p.MobilePhone))
                                {
                                    <div class="small"><i class="bi bi-telephone text-muted me-1"></i>@p.MobilePhone</div>
                                }
                                @if (!string.IsNullOrWhiteSpace(p.Email))
                                {
                                    <div class="small"><i class="bi bi-envelope text-muted me-1"></i>@p.Email</div>
                                }
                            </div>
                        </div>
                    }
                    <div class="d-flex justify-content-between align-items-center mt-2 mb-1">
                        <button class="btn btn-sm btn-outline-secondary" disabled="@(_mobilePage <= 1)" @onclick="() => GoToMobilePageAsync(_mobilePage - 1)">
                            <i class="bi bi-chevron-left"></i> Prev
                        </button>
                        <span class="small text-muted">Page @_mobilePage of @_mobileTotalPages</span>
                        <button class="btn btn-sm btn-outline-secondary" disabled="@(_mobilePage >= _mobileTotalPages)" @onclick="() => GoToMobilePageAsync(_mobilePage + 1)">
                            Next <i class="bi bi-chevron-right"></i>
                        </button>
                    </div>
                }
            </div>
        </div>

        @* Bottom Action Bar *@
        <div class="d-flex flex-wrap justify-content-between align-items-center mt-3 gap-2">
            <div class="d-flex flex-wrap gap-2">
                <button class="btn btn-sm btn-primary" @onclick="@(() => Navigation.NavigateTo("/patients/add"))">
                    <i class="bi bi-person-plus"></i> <span class="d-none d-sm-inline">New Person</span>
                </button>
                <button class="btn btn-sm btn-outline-primary" @onclick="@(() => Navigation.NavigateTo("/patients/add?type=Organisation"))">
                    <i class="bi bi-building-add"></i> <span class="d-none d-sm-inline">New Org</span>
                </button>
                <button class="btn btn-sm btn-outline-danger" @onclick="ArchiveSelectedAsync" disabled="@(_selectedPatient == null)">
                    <i class="bi bi-archive"></i> <span class="d-none d-sm-inline">Archive</span>
                </button>
            </div>
            <div class="dropdown">
                <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown">
                    <i class="bi bi-three-dots"></i> <span class="d-none d-sm-inline">More</span>
                </button>
                <ul class="dropdown-menu dropdown-menu-end">
                    <li><h6 class="dropdown-header">Reports</h6></li>
                    <li><a class="dropdown-item" href="#" @onclick="()=>{}" @onclick:preventDefault><i class="bi bi-bar-chart me-2"></i>Graph</a></li>
                    <li><a class="dropdown-item" href="#" @onclick="ExportCsvAsync" @onclick:preventDefault><i class="bi bi-download me-2"></i>Export</a></li>
                    <li><hr class="dropdown-divider" /></li>
                    <li><h6 class="dropdown-header">Communication</h6></li>
                    <li><a class="dropdown-item" href="#" @onclick:preventDefault><i class="bi bi-chat-dots me-2"></i>Send SMS</a></li>
                    <li><a class="dropdown-item" href="#" @onclick:preventDefault><i class="bi bi-envelope me-2"></i>Send Email</a></li>
                    <li><hr class="dropdown-divider" /></li>
                    <li><h6 class="dropdown-header">Verification</h6></li>
                    <li><a class="dropdown-item" href="#" @onclick:preventDefault><i class="bi bi-shield-check me-2"></i>Enterprise Verification</a></li>
                    <li><a class="dropdown-item" href="#" @onclick="ShowUnderConstruction" @onclick:preventDefault><i class="bi bi-patch-check me-2"></i>Patient Verification</a></li>
                </ul>
            </div>
        </div>
    </div>
</div>

@if (_showPayerPickerModal)
{
    <div class="modal d-block" tabindex="-1" style="background: rgba(0,0,0,0.4);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header py-2">
                    <h6 class="modal-title">Find Payer</h6>
                    <button type="button" class="btn-close" @onclick="@(() => _showPayerPickerModal = false)"></button>
                </div>
                <div class="modal-body">
                    <input class="form-control form-control-sm mb-2" placeholder="Search by name..."
                           @bind="_payerSearchTerm" @bind:event="oninput" @bind:after="SearchPayerCandidatesAsync" />
                    <div style="max-height: 300px; overflow-y: auto;">
                        @if (_payerSearchResults.Count == 0)
                        {
                            <div class="text-muted small">No matches.</div>
                        }
                        else
                        {
                            <ul class="list-group">
                                @foreach (var candidate in _payerSearchResults)
                                {
                                    <li class="list-group-item list-group-item-action" style="cursor:pointer" @onclick="@(() => SelectPayer(candidate))">
                                        @candidate.FullName <span class="text-muted small">(@candidate.DateOfBirth.ToString("dd/MM/yyyy"))</span>
                                    </li>
                                }
                            </ul>
                        }
                    </div>
                </div>
                <div class="modal-footer py-2">
                    <button type="button" class="btn btn-sm btn-secondary" @onclick="@(() => _showPayerPickerModal = false)">Cancel</button>
                </div>
            </div>
        </div>
    </div>
}

@if (_underConstructionMessage != null)
{
    <div class="modal d-block" tabindex="-1" style="background: rgba(0,0,0,0.4);">
        <div class="modal-dialog modal-dialog-centered modal-sm">
            <div class="modal-content">
                <div class="modal-body text-center py-4">
                    <p class="mb-3">@_underConstructionMessage</p>
                    <button class="btn btn-primary btn-sm" @onclick="@(() => _underConstructionMessage = null)">OK</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private RadzenDataGrid<PatientDto>? _grid;
    private List<PatientDto> _patients = new();
    private PatientDto? _selectedPatient;
    private int _totalCount;
    private bool _isLoading;
    private string? _error;
    private int _pageSize = 10;
    private int _mobilePage = 1;
    private int _mobileTotalPages => Math.Max(1, (int)Math.Ceiling((double)_totalCount / _pageSize));
    private string _activeTab = "Basic";
    private string? _underConstructionMessage;

    // Mobile only (the CSS classes ignore this on tablet/desktop): filters start expanded,
    // then collapse after a search so the results have room.
    private bool _mobileFiltersExpanded = true;

    private List<HealthFundDto> _healthFunds = new();
    private PatientSearchDto _filter = new();
    private HashSet<AccountTypeEnum> _selectedAccountTypes = new();

    // Collapsible filter sections — only the first is expanded by default
    private bool _secIdentifiers = true;
    private bool _secAddress = false;
    private bool _secContact = false;
    private bool _secDates = false;
    private bool _secAccount = false;
    private bool _secFlags = false;

    private string? _payerDisplayName;
    private bool _showPayerPickerModal;
    private string _payerSearchTerm = string.Empty;
    private List<PatientDto> _payerSearchResults = new();

    protected override async Task OnInitializedAsync()
    {
        _healthFunds = (await HealthFundService.GetAllActiveAsync()).ToList();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && _grid != null)
        {
            await _grid.Reload();
        }
    }

    /// <summary>Called by RadzenDataGrid whenever it needs a page of data (initial load, paging, Reload()).</summary>
    private async Task LoadDataAsync(LoadDataArgs args)
    {
        _isLoading = true;
        _error = null;
        try
        {
            _filter.Page = (args.Skip ?? 0) / _pageSize + 1;
            _filter.PageSize = _pageSize;
            _filter.AccountTypes = _selectedAccountTypes.Count > 0 ? _selectedAccountTypes.ToList() : null;
            _mobilePage = _filter.Page;

            var result = await PatientService.SearchPatientsAsync(_filter);
            _patients = result.Items.ToList();
            _totalCount = result.TotalCount;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }

    /// <summary>Mobile card-view pager — drives the same (hidden) RadzenDataGrid so loading stays in one place.</summary>
    private async Task GoToMobilePageAsync(int page)
    {
        if (page < 1 || page > _mobileTotalPages || _grid == null) return;
        await _grid.GoToPage(page - 1);
    }

    private async Task FindAsync()
    {
        // GoToPage(0) is a no-op in Radzen when the grid is already on page 0, which would
        // silently ignore a new filter typed while still viewing the first page. Fetch directly
        // instead, then just sync the grid's own paging UI to match.
        await LoadDataAsync(new LoadDataArgs { Skip = 0, Top = _pageSize });
        if (_grid != null)
        {
            await _grid.GoToPage(0);
        }
        _mobileFiltersExpanded = false;
        StateHasChanged();
    }

    private async Task HandleFilterKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await FindAsync();
        }
    }

    private async Task RefreshAsync()
    {
        if (_grid != null)
        {
            await _grid.Reload();
        }
    }

    private void SelectPatient(PatientDto patient)
    {
        _selectedPatient = patient;
    }

    private void ToggleAccountType(AccountTypeEnum type, bool isChecked)
    {
        if (isChecked) _selectedAccountTypes.Add(type);
        else _selectedAccountTypes.Remove(type);
    }

    private void ClearFilters()
    {
        _filter = new PatientSearchDto();
        _selectedAccountTypes.Clear();
        _payerDisplayName = null;
    }

    private void OpenPayerPicker()
    {
        _payerSearchTerm = string.Empty;
        _payerSearchResults = new();
        _showPayerPickerModal = true;
    }

    private async Task SearchPayerCandidatesAsync()
    {
        if (string.IsNullOrWhiteSpace(_payerSearchTerm))
        {
            _payerSearchResults = new();
            return;
        }
        var result = await PatientService.SearchPatientsAsync(new PatientSearchDto { Query = _payerSearchTerm, PageSize = 10 });
        _payerSearchResults = result.Items.ToList();
    }

    private void SelectPayer(PatientDto candidate)
    {
        _filter.PayerPatientId = candidate.Id;
        _payerDisplayName = candidate.FullName;
        _showPayerPickerModal = false;
    }

    private void ClearPayer()
    {
        _filter.PayerPatientId = null;
        _payerDisplayName = null;
    }

    private void EditPatient(PatientDto patient)
    {
        Navigation.NavigateTo($"/patients/edit/{patient.Id}");
    }

    private async Task ArchiveSelectedAsync()
    {
        if (_selectedPatient == null) return;
        await PatientService.ArchivePatientAsync(_selectedPatient.Id);
        _selectedPatient = null;
        if (_grid != null)
        {
            await _grid.Reload();
        }
    }

    private void ShowUnderConstruction()
    {
        _underConstructionMessage = "Under construction";
    }

    private async Task ExportCsvAsync()
    {
        var csv = new StringBuilder();
        csv.AppendLine("FullName,DateOfBirth,Email,PhoneNumber,IsActive");
        foreach (var p in _patients)
        {
            var line = $"\"{p.FullName}\",{p.DateOfBirth:yyyy-MM-dd},\"{p.Email}\",\"{p.Phone}\",{p.IsActive}";
            csv.AppendLine(line);
        }
        var bytes = Encoding.UTF8.GetBytes(csv.ToString());
        var base64 = Convert.ToBase64String(bytes);
        var url = $"data:text/csv;base64,{base64}";
        await JS.InvokeVoidAsync("open", url, "_blank");
    }

    [Inject]
    private IJSRuntime JS { get; set; } = default!;
}
