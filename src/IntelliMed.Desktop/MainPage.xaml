<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:blazor="clr-namespace:Microsoft.AspNetCore.Components.WebView.Maui;assembly=Microsoft.AspNetCore.Components.WebView.Maui"
             xmlns:ui="clr-namespace:IntelliMed.UI;assembly=IntelliMed.UI"
             x:Class="IntelliMed.Desktop.MainPage">

  <blazor:BlazorWebView HostPage="wwwroot/index.html">
    <blazor:BlazorWebView.RootComponents>
      <blazor:RootComponent Selector="#app" ComponentType="{x:Type ui:AppRoot}" />
    </blazor:BlazorWebView.RootComponents>
  </blazor:BlazorWebView>

</ContentPage>
